
@{
    ViewBag.Title = "Quản Lí Đơn Hàng";
    Layout = "~/Views/Shared/_LayoutNguoiBan.cshtml";

    var orders = ViewBag.Orders as IEnumerable<dynamic>;
    if (orders == null)
    {
        orders = new List<dynamic>
{
            new {
                UserName = "Tên người mua",
                ProductImage = Url.Content("~/assets/brand1.png"),
                ProductName = "Tên sp",
                Quantity = 1,
                Total = "₫150.000",
                PaymentNote = "Thanh toán khi nhận hàng",
                StatusBadgeClass = "text-warning",
                FulfillmentStatus = "Chờ lấy hàng",

                CountdownLabel = "Chờ lấy hàng",
                CountdownDate = "27/06/2025",
                Speed = "Giao",
                OrderCode = "2506227N2S4A27",
                PrimaryAction = "Giao",
                SecondaryAction = "In phiếu giao"
            }
        };
    }

    var orderList = orders.ToList();
}

<section class="seller-orders container-fluid px-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="h4 mb-1">@orderList.Count() Kiện hàng</h2>
        </div>
    </div>

    <div class="table-responsive shadow-lg rounded bg-white border-3">
        <table class="table align-middle mb-0">
            <thead class="text-uppercase small text-muted">
                <tr>
                    <th>Mã đơn hàng</th>
                    <th>Sản phẩm</th>
                    <th class="text-center">Tổng cộng</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orderList)
                {
                    <tr class="border-top">
                        <td>
                            <small class="text-muted">@order.OrderCode</small>
                        </td>
                        <td style="min-width: 320px;">
                            <div class="d-flex">
                                <img src="@order.ProductImage" alt="@order.ProductName" class="rounded me-3" style="width:60px;height:60px;object-fit:cover;">
                                <div>
                                    <div class="d-flex align-items-center mb-1">
                                        <strong>@order.ProductName</strong>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">

                                        <span>Số lượng: @order.Quantity</span>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="fw-semibold">@order.Total</div>
                            <small class="text-muted">@order.PaymentNote</small>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span class="fw-semibold">@order.FulfillmentStatus</span>
                            </div>
                        </td>


                        <td class="text-end">
                            <div class="btn-group d-flex flex-column gap-2">
                                <button class="btn btn-sm btn-outline-primary">@order.PrimaryAction</button>
                                <button class="btn btn-sm btn-outline-secondary">@order.SecondaryAction</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

