@model ECommerceWebsiteMVC_Seller.Models.CreateProductViewModel
@{
    Layout = "~/Views/Shared/_LayoutNguoiBan.cshtml";
    var danhMucs = Model.DanhMucs ?? new List<ECommerceWebsiteMVC_Seller.Models.DanhMuc>();
}

<link rel="stylesheet" href="~/Content/seller-create-product.css" />

<div class="create-product-page">
    <div class="page-header">
        <div>
            <h1>Thêm 1 sản phẩm mới</h1>
            <p>Hoàn tất các thông tin bắt buộc để sản phẩm được hiển thị.</p>
        </div>
        <a class="btn btn-outline-secondary" href="@Url.Action("TatCaSanPham", "NguoiBan")">
            <i class="bi bi-arrow-left"></i> Trở về danh sách sản phẩm
        </a>
    </div>

    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    <form action="@Url.Action("ThemSanPham", "NguoiBan")" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AttributeOneName" id="AttributeOneName" />
        <input type="hidden" name="AttributeTwoName" id="AttributeTwoName" />
        <div id="AttributeOneHiddenValues"></div>
        <div id="AttributeTwoHiddenValues"></div>

        <div class="create-product-layout">
            <aside class="suggestion-panel">
                <div class="panel-card">
                    <h4>Gợi ý điền thông tin</h4>
                    <ul>
                        <li>Thêm ít nhất 3 hình ảnh</li>
                        <li>Thêm video sản phẩm</li>
                        <li>Tên sản phẩm có ít nhất 25~100 kí tự</li>
                        <li>Thêm ít nhất 100 kí tự hoặc 1 hình trong mô tả</li>
                        <li>Thêm thương hiệu</li>
                    </ul>
                </div>
                <div class="panel-card">
                    <h4>Gợi ý</h4>
                    <p>Đăng đúng ngành hàng giúp Người mua tìm thấy sản phẩm của bạn nhanh hơn.</p>
                </div>
            </aside>

            <section class="form-section">
                <div class="form-tabs">
                    <button type="button" class="tab-btn active" data-tab="basic">Thông tin cơ bản</button>
                    <button type="button" class="tab-btn" data-tab="description">Mô tả</button>
                    <button type="button" class="tab-btn" data-tab="sales">Thông tin bán hàng</button>
                    <button type="button" class="tab-btn" data-tab="shipping">Vận chuyển</button>
                </div>

                <div class="tab-content active" id="tab-basic">
                    <div class="form-block">
                        <div class="block-header">
                            <h3>Hình ảnh sản phẩm</h3>
                            <span>Chọn tối đa 9 hình ảnh, PNG hoặc JPG, tối đa 5Mb/ảnh.</span>
                        </div>

                        <div class="image-upload-grid">
                            @for (var i = 0; i < 9; i++)
                            {
                                <div class="image-slot">
                                    <label for="product-image-@i">Ảnh @(i + 1)</label>
                                    <input type="file"
                                           id="product-image-@i"
                                           name="ProductImages[@i]"
                                           class="image-input"
                                           accept="image/*" />
                                    <div class="cover-option">
                                        <input type="radio" name="DefaultImageIndex" value="@i" @(i == 0 ? "checked" : null) />
                                        <span>Ảnh bìa</span>
                                    </div>
                                </div>
                            }
                        </div>
                        @Html.ValidationMessage("ProductImages", null, new { @class = "text-danger d-block" })
                    </div>

                    <div class="form-block">
                        <label>Tên sản phẩm <span class="required">*</span></label>
                        @Html.TextBoxFor(m => m.TenSanPham, new { @class = "form-control", maxlength = "120", placeholder = "Ví dụ: Áo thun nam cổ tròn" })
                        @Html.ValidationMessageFor(m => m.TenSanPham, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-block">
                        <label>Ngành hàng <span class="required">*</span></label>
                        @Html.DropDownListFor(m => m.MaDanhMuc,
                            new SelectList(danhMucs, "MaDanhMuc", "TenDanhMuc"),
                            "-- Chọn ngành hàng --",
                            new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.MaDanhMuc, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="tab-content" id="tab-description">
                    <div class="form-block">
                        <label>Mô tả sản phẩm <span class="required">*</span></label>
                        @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = "10", placeholder = "Chia sẻ thông tin nổi bật, chất liệu, kích cỡ..." })
                        @Html.ValidationMessageFor(m => m.MoTa, "", new { @class = "text-danger" })
                        <p class="helper-text">Thêm ít nhất 100 kí tự hoặc đính kèm 1 hình ảnh trong phần mô tả.</p>
                    </div>
                </div>

                <div class="tab-content" id="tab-sales">
                    <div class="form-block">
                        <div class="block-header">
                            <h3>Phân loại hàng</h3>
                            <span>Thiết lập tối đa 2 phân loại (ví dụ: Màu sắc, Size).</span>
                        </div>

                        <div class="variant-attribute" data-attr="first">
                            <label>Tên phân loại 1 <span class="required">*</span></label>
                            <input type="text" id="attr1Name" class="form-control" placeholder="Ví dụ: Màu sắc" autocomplete="off" />
                            @Html.ValidationMessage("AttributeOneName", null, new { @class = "text-danger" })
                            <div class="variant-tags" id="attr1ValueList"></div>
                            <input type="text" class="form-control tag-input" placeholder="Nhập giá trị và nhấn Enter" data-target="first" autocomplete="off" />
                            <span class="helper-text">Tối đa 20 giá trị, nhấn Enter, gõ dấu phẩy hoặc rời khỏi ô để thêm.</span>
                        </div>

                        <div class="variant-attribute d-none" id="attrSecondWrapper" data-attr="second">
                            <div class="attribute-header">
                                <label>Tên phân loại 2</label>
                                <button type="button" class="btn btn-link btn-sm text-danger" id="removeSecondAttribute">Xóa phân loại 2</button>
                            </div>
                            <input type="text" id="attr2Name" class="form-control" placeholder="Ví dụ: Size" autocomplete="off" />
                            <div class="variant-tags" id="attr2ValueList"></div>
                            <input type="text" class="form-control tag-input" placeholder="Nhập giá trị và nhấn Enter" data-target="second" autocomplete="off" />
                            <span class="helper-text">Tối đa 20 giá trị, nhấn Enter, gõ dấu phẩy hoặc rời khỏi ô để thêm.</span>
                        </div>

                        <button type="button" class="btn btn-outline-primary btn-sm" id="addSecondAttribute">
                            <i class="bi bi-plus"></i> Thêm phân loại 2
                        </button>
                    </div>

                    <div class="form-block">
                        <div class="block-header">
                            <h3>Danh sách phân loại hàng</h3>
                            <span>Nhập giá bán, kho và hình ảnh cho từng biến thể.</span>
                        </div>

                        <div class="table-responsive variant-table-wrapper">
                            <table class="table variant-table">
                                <thead>
                                    <tr>
                                        <th>Biến thể</th>
                                        <th>Giá (₫)</th>
                                        <th>Kho hàng</th>
                                        <th>SKU phân loại</th>
                                        <th>Ảnh</th>
                                    </tr>
                                </thead>
                                <tbody id="variantTableBody"></tbody>
                            </table>
                            <div class="variant-empty-state" id="variantEmptyState">
                                Thêm ít nhất 1 giá trị ở phân loại 1 để tạo danh sách biến thể.
                            </div>
                            @Html.ValidationMessage("VariantNames", null, new { @class = "text-danger d-block mt-2" })
                            @for (int i = 0; i < 20; i++)
                            {
                                @Html.ValidationMessage($"VariantImage_{i}", null, new { @class = "text-danger d-block" })
                            }
                        </div>
                    </div>
                </div>

                <div class="tab-content" id="tab-shipping">
                    <div class="form-block">
                        <label>Cân nặng sau khi đóng gói (gr)</label>
                        <input type="number" class="form-control" name="PackageWeight" placeholder="Ví dụ: 500" min="0" />
                    </div>
                    <div class="form-block">
                        <label>Kích thước đóng gói (cm)</label>
                        <div class="dimension-grid">
                            <input type="number" class="form-control" name="DimensionR" placeholder="Dài" min="0" />
                            <input type="number" class="form-control" name="DimensionD" placeholder="Rộng" min="0" />
                            <input type="number" class="form-control" name="DimensionC" placeholder="Cao" min="0" />
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <a href="@Url.Action("TatCaSanPham", "NguoiBan")" class="btn btn-outline-secondary">Hủy</a>
                    <button type="submit" class="btn btn-primary">Lưu &amp; Hiển thị</button>
                </div>
            </section>

            <aside class="preview-panel">
                <div class="preview-card">
                    <h4>Xem trước</h4>
                    <div class="preview-image-placeholder" id="previewMainImage">
                        <i class="bi bi-image"></i>
                    </div>
                    <div class="preview-info">
                        <div class="preview-name" id="previewProductName">Tên sản phẩm</div>
                        <div class="preview-variant-count"><span id="previewVariantCount">0</span> phân loại có sẵn</div>
                        <div class="preview-price" id="previewPrice">₫0</div>
                        <div class="preview-store">Tạp hóa Zzzz</div>
                        <div class="preview-actions">
                            <button type="button" class="btn btn-outline-success btn-sm">Chat</button>
                            <button type="button" class="btn btn-outline-warning btn-sm">Thêm vào giỏ</button>
                            <button type="button" class="btn btn-danger btn-sm">Mua Ngay</button>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </form>
</div>

<script>
    (function () {
        // Tab handling
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                document.getElementById('tab-' + this.dataset.tab).classList.add('active');
            });
        });

        // Preview update
        const productNameInput = document.getElementById('@Html.IdFor(m => m.TenSanPham)');
        const previewName = document.getElementById('previewProductName');
        productNameInput?.addEventListener('input', function () {
            previewName.textContent = this.value.trim() || 'Tên sản phẩm';
        });

        // Variant builder state
        const attributeState = {
            first: { nameInput: document.getElementById('attr1Name'), values: [] },
            second: { nameInput: document.getElementById('attr2Name'), values: [], enabled: false }
        };

        const addSecondBtn = document.getElementById('addSecondAttribute');
        const secondWrapper = document.getElementById('attrSecondWrapper');
        const removeSecondBtn = document.getElementById('removeSecondAttribute');

        addSecondBtn.addEventListener('click', () => {
            secondWrapper.classList.remove('d-none');
            addSecondBtn.classList.add('d-none');
            attributeState.second.enabled = true;
            syncAttributeName('second');
            renderVariantTable();
        });

        removeSecondBtn.addEventListener('click', () => {
            secondWrapper.classList.add('d-none');
            addSecondBtn.classList.remove('d-none');
            attributeState.second.enabled = false;
            attributeState.second.values = [];
            document.getElementById('attr2ValueList').innerHTML = '';
            document.getElementById('AttributeTwoHiddenValues').innerHTML = '';
            document.getElementById('attr2Name').value = '';
            document.getElementById('AttributeTwoName').value = '';
            renderVariantTable();
        });

        document.querySelectorAll('.tag-input').forEach(input => {
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ',') {
                    e.preventDefault();
                    const value = this.value.trim();
                    if (!value) return;
                    const attrKey = this.dataset.target;
                    addAttributeValue(attrKey, value);
                    this.value = '';
                }
            });

            input.addEventListener('blur', function () {
                const value = this.value.trim();
                if (!value) return;
                const attrKey = this.dataset.target;
                addAttributeValue(attrKey, value);
                this.value = '';
            });
        });

        attributeState.first.nameInput.addEventListener('input', () => syncAttributeName('first'));
        attributeState.second.nameInput.addEventListener('input', () => syncAttributeName('second'));

        function syncAttributeName(key) {
            const hiddenId = key === 'first' ? 'AttributeOneName' : 'AttributeTwoName';
            document.getElementById(hiddenId).value = attributeState[key].nameInput.value.trim();
            renderVariantTable();
        }

        function addAttributeValue(key, rawValue) {
            const state = attributeState[key];
            if (!state) return;
            if (!attributeState.second.enabled && key === 'second') return;
            const values = rawValue.split(',')
                .map(v => v.trim())
                .filter(v => v.length > 0);

            if (!values.length) return;

            let added = false;
            values.forEach(value => {
                if (state.values.includes(value)) return;
                if (state.values.length >= 20) return;
                state.values.push(value);
                added = true;
            });

            if (added) {
                renderAttributeValues(key);
                syncHiddenValues(key);
                renderVariantTable();
            }
        }

        function removeAttributeValue(key, value) {
            const state = attributeState[key];
            state.values = state.values.filter(v => v !== value);
            renderAttributeValues(key);
            syncHiddenValues(key);
            renderVariantTable();
        }

        function renderAttributeValues(key) {
            const container = document.getElementById(key === 'first' ? 'attr1ValueList' : 'attr2ValueList');
            container.innerHTML = '';
            attributeState[key].values.forEach(value => {
                const pill = document.createElement('span');
                pill.className = 'variant-pill';
                pill.innerHTML = `${value} <button type="button" class="pill-remove" aria-label="Xóa">&times;</button>`;
                pill.querySelector('button').addEventListener('click', () => removeAttributeValue(key, value));
                container.appendChild(pill);
            });
        }

        function syncHiddenValues(key) {
            const hiddenContainer = document.getElementById(key === 'first' ? 'AttributeOneHiddenValues' : 'AttributeTwoHiddenValues');
            hiddenContainer.innerHTML = '';
            attributeState[key].values.forEach(value => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = key === 'first' ? 'AttributeOneValues' : 'AttributeTwoValues';
                input.value = value;
                hiddenContainer.appendChild(input);
            });
        }

        function renderVariantTable() {
            const tableBody = document.getElementById('variantTableBody');
            const emptyState = document.getElementById('variantEmptyState');
            const previewVariantCount = document.getElementById('previewVariantCount');

            const existingData = {};
            tableBody.querySelectorAll('.variant-row').forEach(row => {
                const key = row.dataset.variantKey;
                existingData[key] = {
                    price: row.querySelector('input[name="VariantPrices"]')?.value || '',
                    stock: row.querySelector('input[name="VariantStocks"]')?.value || '',
                    sku: row.querySelector('input[name="VariantSkus"]')?.value || ''
                };
            });

            tableBody.innerHTML = '';

            if (!attributeState.first.values.length) {
                emptyState.classList.remove('d-none');
                previewVariantCount.textContent = '0';
                return;
            }

            emptyState.classList.add('d-none');

            const secondValues = attributeState.second.enabled && attributeState.second.values.length
                ? attributeState.second.values
                : [null];

            let combinationCount = 0;
            let variantIndex = 0;

            attributeState.first.values.forEach(firstValue => {
                secondValues.forEach(secondValue => {
                    const key = secondValue ? `${firstValue}|${secondValue}` : firstValue;
                    const existing = existingData[key] || {};

                    const row = document.createElement('tr');
                    row.className = 'variant-row';
                    row.dataset.variantKey = key;
                    row.innerHTML = `
                        <td>
                            <div class="variant-name">
                                <span>${firstValue}</span>
                                ${secondValue ? `<span class="divider">|</span><span>${secondValue}</span>` : ''}
                            </div>
                            <input type="hidden" name="VariantNames" value="${key}">
                        </td>
                        <td><input type="number" class="form-control" name="VariantPrices" min="0" placeholder="Nhập giá" value="${existing.price || ''}" required></td>
                        <td><input type="number" class="form-control" name="VariantStocks" min="0" placeholder="Kho" value="${existing.stock || ''}" required></td>
                        <td><input type="text" class="form-control" name="VariantSkus" placeholder="SKU" value="${existing.sku || ''}"></td>
                        <td>
                            <div class="variant-image-upload">
                                <label class="variant-image-label" for="variantImage_${variantIndex}">
                                    <span class="upload-text">Chọn ảnh <span class="required">*</span></span>
                                    <input type="file" 
                                           id="variantImage_${variantIndex}" 
                                           name="VariantImage_${variantIndex}" 
                                           accept="image/*" 
                                           class="variant-image-input" 
                                           data-variant-index="${variantIndex}"
                                           required>
                                </label>
                                <div class="variant-image-preview" id="preview_${variantIndex}" style="display: none;">
                                    <img src="" alt="Preview" class="preview-img">
                                    <button type="button" class="remove-preview" data-variant-index="${variantIndex}">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                            </div>
                        </td>`;

                    tableBody.appendChild(row);
                    combinationCount++;
                    variantIndex++;
                });
            });

            previewVariantCount.textContent = combinationCount.toString();

            // Attach image preview handlers to new rows
            attachImagePreviewHandlers();

            // Attach price update handlers for preview
            attachPriceUpdateHandlers();
        }

        function attachPriceUpdateHandlers() {
            document.querySelectorAll('input[name="VariantPrices"]').forEach(input => {
                input.addEventListener('input', function() {
                    updatePricePreview();
                });
            });
        }

        function updatePricePreview() {
            const prices = Array.from(document.querySelectorAll('input[name="VariantPrices"]'))
                .map(input => {
                    const val = parseFloat(input.value);
                    return isNaN(val) ? null : val;
                })
                .filter(p => p !== null);

            const previewPrice = document.getElementById('previewPrice');
            if (prices.length === 0) {
                previewPrice.textContent = '₫0';
            } else if (prices.length === 1) {
                previewPrice.textContent = '₫' + prices[0].toLocaleString('vi-VN');
            } else {
                const minPrice = Math.min(...prices);
                const maxPrice = Math.max(...prices);
                if (minPrice === maxPrice) {
                    previewPrice.textContent = '₫' + minPrice.toLocaleString('vi-VN');
                } else {
                    previewPrice.textContent = '₫' + minPrice.toLocaleString('vi-VN') + ' - ₫' + maxPrice.toLocaleString('vi-VN');
                }
            }
        }

        function attachImagePreviewHandlers() {
            document.querySelectorAll('.variant-image-input').forEach(input => {
                input.addEventListener('change', function(e) {
                    const file = this.files[0];
                    const variantIndex = this.dataset.variantIndex;
                    const previewDiv = document.getElementById(`preview_${variantIndex}`);
                    const previewImg = previewDiv?.querySelector('.preview-img');
                    const uploadLabel = this.closest('.variant-image-upload').querySelector('.variant-image-label');

                    if (file && previewDiv && previewImg) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            previewImg.src = e.target.result;
                            previewDiv.style.display = 'block';
                            uploadLabel.style.display = 'none';
                        };
                        reader.readAsDataURL(file);
                    }
                });
            });

            document.querySelectorAll('.remove-preview').forEach(btn => {
                btn.addEventListener('click', function() {
                    const variantIndex = this.dataset.variantIndex;
                    const previewDiv = document.getElementById(`preview_${variantIndex}`);
                    const input = document.getElementById(`variantImage_${variantIndex}`);
                    const uploadLabel = input?.closest('.variant-image-upload').querySelector('.variant-image-label');

                    if (previewDiv && input && uploadLabel) {
                        previewDiv.style.display = 'none';
                        uploadLabel.style.display = 'block';
                        input.value = '';
                    }
                });
            });
        }

        // Form validation before submit
        const form = document.querySelector('form[action*="ThemSanPham"]');
        form?.addEventListener('submit', function(e) {
            const variantImages = document.querySelectorAll('.variant-image-input');
            let hasError = false;
            const errorMessages = [];

            variantImages.forEach(input => {
                if (!input.files || input.files.length === 0) {
                    hasError = true;
                    const row = input.closest('tr');
                    if (row) {
                        row.classList.add('variant-error');
                        const variantName = row.querySelector('.variant-name')?.textContent.trim() || 'biến thể';
                        if (!errorMessages.includes(variantName)) {
                            errorMessages.push(variantName);
                        }
                    }
                } else {
                    const row = input.closest('tr');
                    if (row) {
                        row.classList.remove('variant-error');
                    }
                }
            });

            if (hasError) {
                e.preventDefault();
                alert('Vui lòng tải lên ảnh cho tất cả các biến thể:\n' + errorMessages.join('\n'));
                return false;
            }
        });
    })();
</script>



