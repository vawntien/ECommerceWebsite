@using ECommerceWebsiteMVC_Seller.Models
@model SanPham
@{
    ViewBag.Title = "Các đánh giá của sản phẩm";
    Layout = "~/Views/Shared/_LayoutNguoiBan.cshtml";

    List<DanhGiaSanPham> dsDG = ViewBag.DanhSachDanhGia;
    var macdinh = Model.AnhSanPhams
    .Where(x => x.MacDinh == true)
    .Select(x => x.HinhAnh)
    .FirstOrDefault()
    ?? Model.AnhSanPhams
        .Select(x => x.HinhAnh)
        .FirstOrDefault();

    var productImageUrl = !string.IsNullOrEmpty(macdinh)
        ? $"https://ecommerceshopstorage.blob.core.windows.net/products/{Model.MaSanPham}/{macdinh}"
        : "https://via.placeholder.com/80?text=No+Image";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
    tailwind.config = {
        prefix: 'tw-',
        important: true,
        corePlugins: {
            preflight: false
        }
    }
</script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<style>
    .star-rating {
        display: inline-flex;
        gap: 0.25rem;
    }

        .star-rating .material-icons {
            font-size: 1.75rem;
            color: #f59e0b;
            cursor: pointer;
            user-select: none;
        }

    .review-form-field {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

        .review-form-field.horizontal {
            display: grid;
            grid-template-columns: 160px 1fr;
            align-items: center;
            gap: 1rem;
        }

        .review-form-field.textarea-field {
            display: grid;
            grid-template-columns: 160px 1fr;
            align-items: start;
            gap: 1rem;
        }

    .review-input-wrapper {
        width: 100%;
    }

        .review-input-wrapper input,
        .review-input-wrapper textarea {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #d1d5db;
            border-radius: 0.375rem;
            background-color: white;
        }

            .review-input-wrapper input[readonly],
            .review-input-wrapper textarea[readonly] {
                background-color: #f3f4f6;
                cursor: not-allowed;
            }

            .review-input-wrapper input:focus,
            .review-input-wrapper textarea:focus {
                outline: none;
                border-color: #f97316;
                box-shadow: 0 0 0 1px #f97316;
            }

        .review-input-wrapper textarea {
            height: 128px;
            resize: vertical;
        }

    /* Modal overlay */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.4);
        z-index: 50;
    }

        .modal-overlay.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .modal-content {
        background: white;
        border-radius: 0.5rem;
        padding: 2rem;
        max-width: 42rem;
        width: calc(100% - 2rem);
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        position: relative;
    }

        .modal-content.dark {
            background: #1e293b;
            color: #e5e7eb;
        }

    .modal-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: #9ca3af;
        padding: 0.5rem;
    }

        .modal-close:hover {
            color: #6b7280;
        }

    .modal-title {
        font-size: 1.875rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.5rem;
    }

    .modal-content.dark .modal-title {
        color: #f3f4f6;
    }
</style>

<main class="tw-p-6 lg:tw-p-10">

    <div class="tw-mx-auto tw-max-w-5xl">

        <!-- =================================================================== -->
        <!-- 🟦 THÔNG TIN SẢN PHẨM -->
        <!-- =================================================================== -->
        <div class="tw-mb-10 tw-rounded-lg tw-bg-white tw-p-6 tw-shadow-sm tw-border tw-border-gray-200">

            <h2 class="tw-text-lg tw-font-bold tw-mb-4 tw-text-gray-900">Thông tin sản phẩm</h2>

            <div class="tw-flex tw-flex-col tw-items-start tw-gap-6 md:tw-flex-row md:tw-items-center md:tw-justify-between">

                <div class="tw-flex tw-items-center tw-gap-6">

                    <!-- Avatar cửa hàng -->
                    <div class="tw-bg-center tw-bg-cover  tw-h-24 tw-w-24"
                         style='background-image: url(@productImageUrl);'>
                    </div>
                    @*<img src="@productImageUrl" class="tw-w-full tw-h-full tw-object-cover" />*@


                    <div class="tw-flex tw-flex-col tw-gap-1">
                        <p class="tw-text-gray-900 tw-text-xl tw-font-bold">
                            @Model.TenSanPham
                        </p>



                        <p class="tw-text-gray-600 tw-text-sm">
                            Mã sản phẩm: @Model.MaSanPham
                        </p>

                        <p class="tw-text-gray-600 tw-text-sm">
                            Số sao trung bình: @Model.SoSaoTrungBinh
                        </p>
                    </div>
                </div>



            </div>
        </div>



        <!-- =================================================================== -->
        <!-- DANH SÁCH ĐÁNH GIÁ -->
        <!-- =================================================================== -->
        <div class="tw-overflow-hidden tw-rounded-lg tw-bg-white tw-shadow-sm tw-border tw-border-gray-200">
            <div class="tw-overflow-x-auto">

                <table class="tw-w-full tw-text-left tw-text-sm tw-text-gray-700">
                    <thead class="tw-bg-gray-100 tw-text-xs tw-uppercase tw-text-gray-600">
                        <tr>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Mã đánh giá</th>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Thời gian</th>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Khách Hàng</th>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Số sao</th>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Tiêu đề</th>
                            <th class="tw-px-6 tw-py-3 tw-font-medium">Hành động</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var dg in dsDG)
                        {
                            <tr class="tw-border-b tw-border-gray-200">

                                <td class="tw-px-6 tw-py-4 tw-font-medium tw-text-gray-900">
                                    @dg.MaDG
                                </td>

                                <td class="tw-px-6 tw-py-4">@dg.ThoiGian.Value.ToString("dd/MM/yyyy")</td>

                                <td class="tw-px-6 tw-py-4">@dg.ChiTietDonHang.ChiTietGioHang.GioHang.NguoiMua.TaiKhoan</td>


                                <td class="tw-px-6 tw-py-4">@dg.SoSao</td>
                                <td class="tw-px-6 tw-py-4">@dg.TieuDe</td>

                                <td class="tw-px-6 tw-py-4">
                                    <div class="tw-flex tw-items-center tw-justify-center">
                                        <button type="button"
                                                class="tw-flex tw-items-center tw-justify-center tw-rounded tw-h-10 tw-px-5 tw-bg-red-500 tw-text-white tw-text-sm tw-font-bold hover:tw-bg-red-600 tw-border-0 btnChiTietDanhGia"
                                                data-id="@dg.MaDG">
                                            Chi tiết
                                        </button>
                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

    </div>

</main>

<!-- Modal Chi tiết đánh giá sản phẩm -->
<div id="product-review-modal" class="modal-overlay">
    <div class="modal-content">
        <button type="button" class="modal-close" onclick="closeReviewModal()">
            <span class="material-icons">close</span>
        </button>

        <h1 class="modal-title">Chi tiết Đánh Giá Sản Phẩm</h1>

        <div id="modalReviewContent">
            <!-- Nội dung sẽ được load bằng AJAX -->
        </div>
    </div>
</div>

<script>
    function closeReviewModal() {
        var modal = document.getElementById('product-review-modal');
        modal.classList.remove('active');
        var content = document.getElementById('modalReviewContent');
        if (content) content.innerHTML = '';
    }

    // mở modal khi click nút Chi tiết
    document.addEventListener('click', function (e) {
        if (e.target.classList.contains('btnChiTietDanhGia')) {
            var maDG = e.target.getAttribute('data-id');
            var modal = document.getElementById('product-review-modal');
            var modalContent = document.getElementById('modalReviewContent');

            modalContent.innerHTML = '<div style="text-align: center; padding: 1rem;"><span>Đang tải...</span></div>';
            modal.classList.add('active');

            // Load chi tiết đánh giá từ server
            fetch('@Url.Action("ChiTietDanhGia", "NguoiBan")?pMaDG=' + maDG)
                .then(response => response.text())
                .then(html => {
                    modalContent.innerHTML = html;
                    initializeReviewModal();
                })
                .catch(error => {
                    modalContent.innerHTML = '<div style="color: #dc2626;">Lỗi khi tải dữ liệu</div>';
                });
        }
    });

    // đóng modal khi click nền
    document.addEventListener('click', function (e) {
        var modal = document.getElementById('product-review-modal');
        if (e.target === modal) {
            closeReviewModal();
        }
    });

    // Khởi tạo lại các event cho modal khi tải nội dung
    function initializeReviewModal() {
        var starsContainer = document.getElementById('review-stars');
        var hiddenInput = document.getElementById('SoSao');
        var ratingText = document.getElementById('rating-text');
        var labels = ["", "Tệ", "Tạm ổn", "Khá", "Tốt", "Tuyệt vời"];

        if (starsContainer && hiddenInput) {
            var stars = starsContainer.querySelectorAll('.material-icons');

            function render(value) {
                stars.forEach(function (s) {
                    var v = parseInt(s.getAttribute('data-value'));
                    s.textContent = v <= value ? 'star' : 'star_border';
                });
                if (ratingText) ratingText.textContent = labels[value] || "";
            }

            var initial = parseInt(hiddenInput.value) || 5;
            render(initial);

            // Disable star clicking since it's read-only
            stars.forEach(function (s) {
                s.style.cursor = 'default';
                s.style.pointerEvents = 'none';
            });
        }

        @*// Setup delete button from partial view
        var deleteBtn = document.getElementById('btnDeleteReview');
        if (deleteBtn && !deleteBtn.dataset.initialized) {
            deleteBtn.dataset.initialized = 'true';

            deleteBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();

                if (!confirm('Bạn chắc chắn muốn xóa đánh giá này?')) return;

                var maDG = this.getAttribute('data-madg');

                fetch('@Url.Action("XoaDanhGia", "QuanLyNguoiDungHeThong")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'pMaDG=' + encodeURIComponent(maDG)
                })
                .then(res => {
                    if (!res.ok) {
                        throw new Error('Network response was not ok: ' + res.status);
                    }
                    return res.json();
                })
                .then(data => {
                    if (data && data.success) {
                        alert('Xóa thành công');
                        location.reload();
                    } else {
                        alert('Xóa thất bại: ' + (data.message || 'Lỗi không xác định'));
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Có lỗi xảy ra: ' + err.message);
                });
            });
        }*@
    }
</script>
