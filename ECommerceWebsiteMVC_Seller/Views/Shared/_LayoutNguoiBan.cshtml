﻿
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kênh Người Bán</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/Content/StyleSheet1.css" asp-append-version="true" />
</head>
<body>

    <header class="seller-header navbar navbar-expand navbar-light bg-white fixed-top shadow-sm">
        <div class="container-fluid mt-0">
            <a class="navbar-brand" href="/NguoiMua/Index">
                <img class="navbar-brand" src="~/assets/brand1.png" alt="ba" /> Kênh Người Bán
            </a>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="bi bi-bell fs-5"></i></a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="bi bi-question-circle fs-5"></i></a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">

                        @(Session["TenShop"] != null ? Session["TenShop"].ToString() : "Tài khoản")
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                        <li>
                            <a class="dropdown-item d-flex align-items-center" href="@Url.Action("HoSoNguoiBan", "TaiKhoan")">
                                <i class="fa-regular fa-user me-2" style="width: 20px; text-align: center;"></i>
                                <span>Hồ sơ của tôi</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center text-danger" href="@Url.Action("DangXuatNguoiBan", "TaiKhoan")">
                                <i class="fa-solid fa-arrow-right-from-bracket me-2" style="width: 20px; text-align: center;"></i>
                                <span>Đăng xuất</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </header>

    <div class="seller-body-wrapper">

        <nav class="seller-sidebar">
            <ul class="nav flex-column sidebar-nav">

                <li class="nav-item">
                    <a class="nav-link active" href="#">
                        <i class="bi bi-house-door"></i>
                        <span>Tổng quan</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/DonHang/Index/">
                        <i class="bi bi-clipboard-data"></i>
                        <span>Quản Lý Đơn Hàng</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#san-pham-nav" aria-expanded="false" aria-controls="san-pham-nav">
                        <i class="bi bi-box-seam"></i>
                        <span>Quản Lý Sản Phẩm</span>
                        <i class="bi bi-chevron-down ms-auto"></i>
                    </a>
                    <ul id="san-pham-nav" class="nav-content collapse" data-bs-parent=".sidebar-nav">
                        <li><a href="/NguoiBan/TatCaSanPham">Tất cả Sản Phẩm</a></li>
                        <li><a href="@Url.Action("ThemSanPham", "NguoiBan")">Thêm Sản Phẩm</a></li>
                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>Phân Tích Bán Hàng</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-bullhorn"></i>
                        <span>Kênh Marketing</span>
                    </a>
                </li>

            </ul>
        </nav>

        <main class="seller-content">

            @RenderBody()

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
</body>
</html>