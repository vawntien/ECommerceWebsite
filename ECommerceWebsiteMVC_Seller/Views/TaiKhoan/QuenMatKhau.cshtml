@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shopee - Quên mật khẩu Kênh Người Bán</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        .forgot-page {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: #fff;
        }

            /* HEADER */
            .forgot-page .top-header {
                background: #fff;
                padding: 12px 0;
                box-shadow: 0 1px 2px rgba(0,0,0,.05);
            }

            /* HERO SECTION */
            .forgot-page .hero {
                background: #ee4d2d;
                padding: 80px 0;
            }

            .forgot-page .hero-left {
                text-align: center;
                padding: 40px 20px;
                color: #fff;
            }

                .forgot-page .hero-left img {
                    width: 160px;
                }

            .forgot-page .hero-slogan .line1,
            .forgot-page .hero-slogan .line2 {
                white-space: nowrap;
                font-size: clamp(26px, 4vw, 30px);
                line-height: 1.3;
                color: #fff;
                font-weight: 300;
            }

            /* FORM BOX */
            .forgot-page .login-box {
                background: #fff;
                border-radius: 4px;
                padding: 40px;
                width: 100%;
                max-width: 450px;
                box-shadow: 0 12px 30px rgba(0,0,0,.16);
            }

            .forgot-page .btn-next {
                background: #ee4d2d;
                color: #fff;
                border: none;
                height: 50px;
                font-size: 16px;
                font-weight: 500;
                text-transform: uppercase;
                border-radius: 2px;
            }

                .forgot-page .btn-next:hover {
                    background: #c5311d;
                }

                .forgot-page .btn-next:disabled {
                    opacity: 0.8;
                }

            /* FOOTER */
            .forgot-page footer {
                background: #fafafa;
                padding: 60px 0;
                font-size: 13px;
                color: #777;
                border-top: 1px solid #e0e0e0;
            }

                .forgot-page footer a {
                    display: block;
                    color: #555;
                    text-decoration: none;
                    margin-bottom: 6px;
                }

                    .forgot-page footer a:hover {
                        color: #ee4d2d;
                    }

            .forgot-page .footer-bottom {
                background: #fff;
                border-top: 1px solid #ddd;
                padding: 40px 0;
                font-size: 13px;
                color: rgba(0,0,0,.54);
            }

            .forgot-page .footer-locations span {
                padding: 0 8px;
                border-right: 1px solid #cfcfcf;
            }

                .forgot-page .footer-locations span:last-child {
                    border-right: none;
                }
    </style>
</head>

<body class="forgot-page">

    <header class="top-header">
        <div class="container d-flex align-items-center">
            <a href="@Url.Action("Index", "NguoiBan")"
               style="text-decoration:none; display:flex; align-items:center;">
                <img src="~/assets/brand1.png" height="42" />
                <span style="font-size:22px;color:#ee4d2d;font-weight:700;margin-left:5px;margin-right:20px;">
                    Shopee
                </span>
            </a>
            <span style="font-size:20px;border-left:1px solid #ccc;padding-left:15px;">
                Quên mật khẩu Kênh Người Bán
            </span>
        </div>
    </header>

    <section class="hero">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-lg-6 d-none d-lg-block hero-left">
                    <img src="~/assets/shope.png" />
                    <div class="hero-slogan">
                        <div class="line1">Quản lý Shop chuyên nghiệp</div>
                        <div class="line2">Phát triển kinh doanh cùng Shopee</div>
                    </div>
                </div>

                <div class="col-lg-6 d-flex justify-content-center">
                    <div class="login-box">
                        <h3 class="mb-4 fw-normal">Thiết lập lại mật khẩu</h3>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger"
                                 style="font-size:14px;background:#fff9fa;border:none;color:#ff424f;">
                                <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
                            </div>
                        }

                        @using (Html.BeginForm("QuenMatKhau", "TaiKhoan", FormMethod.Post, new { id = "forgotForm" }))
                        {
                            <div class="mb-3">
                                <input type="text" name="TaiKhoan"
                                       class="form-control shadow-none"
                                       placeholder="Tên đăng nhập Người bán" required />
                            </div>

                            <div class="mb-3">
                                <input type="email" name="Email"
                                       class="form-control shadow-none"
                                       placeholder="Email đăng ký" required />
                            </div>

                            <div class="mb-3">
                                <input type="text" name="SDT"
                                       class="form-control shadow-none"
                                       placeholder="Số điện thoại" required />
                            </div>

                            <div class="mb-4">
                                <input type="text" name="CCCD" id="inputCCCD"
                                       class="form-control shadow-none"
                                       placeholder="Số Căn cước công dân (12 số)"
                                       maxlength="12" required pattern="[0-9]{12}" />
                            </div>

                            <button type="submit" class="btn btn-next w-100" id="btnNext">
                                <span id="btnText">TIẾP THEO</span>
                                <span class="spinner-border spinner-border-sm ms-2 d-none"
                                      id="loadingSpinner"></span>
                            </button>

                            <div class="text-center mt-4" style="font-size:14px;">
                                <a href="@Url.Action("DangNhapNguoiBan","TaiKhoan")"
                                   style="text-decoration:none;color:#ee4d2d;">
                                    <i class="fa-solid fa-chevron-left small"></i> Quay lại Đăng nhập
                                </a>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">HỖ TRỢ NGƯỜI BÁN</h6>
                    <a href="#">Trung tâm trợ giúp</a>
                    <a href="#">Quy định đăng bán</a>
                    <a href="#">Chính sách Người bán</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">VỀ SHOPEE</h6>
                    <a href="#">Giới thiệu</a>
                    <a href="#">Tuyển dụng</a>
                    <a href="#">Chính sách bảo mật</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">THANH TOÁN</h6>
                    <a href="#">Ví ShopeePay</a>
                    <a href="#">Ngân hàng liên kết</a>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">THEO DÕI CHÚNG TÔI</h6>
                    <a href="#"><i class="fa-brands fa-facebook me-2"></i> Facebook</a>
                    <a href="#"><i class="fa-brands fa-instagram me-2"></i> Instagram</a>
                </div>
            </div>
        </div>
    </footer>

    <div class="footer-bottom">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <span>© 2025 Shopee Kênh Người Bán. Tất cả các quyền được bảo lưu.</span>
            <div class="footer-locations mt-3 mt-md-0">
                Quốc gia & Khu vực:
                <span>Singapore</span>
                <span>Indonesia</span>
                <span>Thái Lan</span>
                <span>Việt Nam</span>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById("forgotForm");
        const btn = document.getElementById("btnNext");
        const spinner = document.getElementById("loadingSpinner");
        const btnText = document.getElementById("btnText");
        const inputCCCD = document.getElementById("inputCCCD");

        // Chặn nhập ký tự không phải số vào CCCD
        inputCCCD.addEventListener("input", function (e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        form.addEventListener("submit", function () {
            if (inputCCCD.value.length === 12) {
                btn.disabled = true;
                spinner.classList.remove("d-none");
                btnText.textContent = "Đang xử lý...";
            }
        });
    </script>

</body>
</html>