@{
    Layout = null;
    var buyer = ViewBag.NguoiMua as ECommerceWebsiteMVC_Seller.Models.NguoiMua;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shopee - Đăng ký bán hàng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f5f5;
            font-family: Arial, sans-serif;
        }

        .header {
            background: #fff;
            padding: 15px 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
            margin-bottom: 30px;
        }

        .container-form {
            max-width: 600px;
            margin: 0 auto;
            background: #fff;
            padding: 40px;
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
        }

        .form-control[readonly] {
            background-color: #f9f9f9;
            color: #666;
            cursor: not-allowed;
        }

        .btn-submit {
            background: #ee4d2d;
            color: #fff;
            width: 100%;
            height: 45px;
            border: none;
            font-size: 16px;
            border-radius: 2px;
        }

            .btn-submit:hover {
                background: #d73211;
            }
    </style>
</head>
<body>

    <div class="header">
        <div class="container d-flex align-items-center">
            <img src="~/assets/brand1.png" height="40" />
            <span style="font-size: 24px; color: #ee4d2d; font-weight: 500; margin-left: 15px;">Đăng ký Bán hàng</span>
        </div>
    </div>

    <div class="container">
        <div class="container-form">
            <h4 class="mb-4">Bổ sung thông tin định danh</h4>
            <p class="text-muted small mb-4">
                Xin chào <strong>@buyer.HoVaTen</strong>! Để trở thành người bán, vui lòng bổ sung số Căn cước công dân (CCCD).
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small">@ViewBag.Error</div>
            }

            <form method="post" action="@Url.Action("HoanTatDangKyNguoiBan", "TaiKhoan")">
                <input type="hidden" name="MaNguoiMua" value="@buyer.MaNguoiMua" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Họ và tên</label>
                        <input type="text" class="form-control" value="@buyer.HoVaTen" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted">Tài khoản</label>
                        <input type="text" class="form-control" value="@buyer.TaiKhoan" readonly />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Số điện thoại</label>
                    <input type="text" class="form-control" value="@buyer.SDT" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label small text-muted">Email</label>
                    <input type="text" class="form-control" value="@buyer.Email" readonly />
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Số Căn Cước Công Dân (CCCD) <span class="text-danger">*</span></label>
                    <input type="text" name="CCCD" class="form-control py-2 border-danger"
                           placeholder="Nhập số CCCD của bạn"
                           required pattern="[0-9]{12}" title="CCCD phải gồm 12 chữ số" />
                    <div class="form-text text-muted small">Thông tin này dùng để xác minh danh tính người bán.</div>
                </div>

                <button type="submit" class="btn btn-submit">HOÀN TẤT ĐĂNG KÝ</button>

                <div class="text-center mt-3">
                    <a href="/TaiKhoan/DangNhapNguoiBan" class="text-decoration-none text-secondary small">Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>