@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shopee - Đăng nhập Kênh Người Bán</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .login-page {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: #fff;
        }

            /* HEADER */
            .login-page .top-header {
                background: #fff;
                padding: 12px 0;
                box-shadow: 0 1px 2px rgba(0,0,0,.05);
            }

            /* HERO */
            .login-page .hero {
                background: #ee4d2d;
                padding: 80px 0;
            }

            .login-page .hero-left {
                text-align: center;
                padding: 40px 20px;
                color: #fff;
            }

                .login-page .hero-left img {
                    width: 160px;
                }

            .login-page .hero-slogan .line1,
            .login-page .hero-slogan .line2 {
                white-space: nowrap;
                font-size: clamp(26px, 4vw, 30px);
                line-height: 1.3;
                color: #fff;
            }

            /* LOGIN BOX */
            .login-page .login-box {
                background: #fff;
                border-radius: 4px;
                padding: 40px;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 12px 30px rgba(0,0,0,.16);
            }

            .login-page .btn-next {
                background: #ee4d2d;
                color: #fff;
                border: none;
                height: 50px;
                font-size: 16px;
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
            }

                .login-page .btn-next:hover {
                    background: #c5311d;
                }

                .login-page .btn-next:disabled {
                    opacity: 0.8;
                    cursor: not-allowed;
                }

            .login-page .toggle-password {
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                cursor: pointer;
            }

            /* FOOTER */
            .login-page footer {
                background: #fafafa;
                padding: 50px 0;
                font-size: 13px;
                color: #777;
            }

                .login-page footer a {
                    display: block;
                    color: #555;
                    text-decoration: none;
                    margin-bottom: 6px;
                    font-size: 13px;
                }

                    .login-page footer a:hover {
                        color: #ee4d2d;
                    }

            .login-page .footer-bottom {
                background: #fff;
                border-top: 1px solid #ddd;
                padding: 20px 0;
                font-size: 13px;
                display: flex;
                justify-content: center;
                gap: 30px;
                flex-wrap: wrap;
            }

            .login-page .footer-locations span {
                padding: 0 8px;
                border-right: 1px solid #cfcfcf;
            }

                .login-page .footer-locations span:last-child {
                    border-right: none;
                }
    </style>
</head>

<body class="login-page">

    <header class="top-header">
        <div class="container d-flex align-items-center">
            <a href="@Url.Action("Index", "NguoiMua")" style="text-decoration:none; display:flex; align-items:center;">
                <img src="~/assets/brand1.png" style="margin-left:0;" height="42" />
                <span style="font-size:22px;color:#ee4d2d;font-weight:700;margin-left:5px;margin-right:20px;">
                    Shopee
                </span>
            </a>
            <span style="font-size:20px; border-left: 1px solid #ddd; padding-left: 20px;">Kênh Người Bán</span>
        </div>
    </header>

    <section class="hero">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-lg-6 d-none d-lg-block hero-left">
                    <img src="~/assets/shope.png" />
                    <div class="hero-slogan">
                        <div class="line1">Quản lý Shop chuyên nghiệp</div>
                        <div class="line2">Phát triển kinh doanh cùng Shopee</div>
                    </div>
                </div>

                <div class="col-lg-6 d-flex justify-content-center">
                    <div class="login-box">
                        <h3 class="mb-4">Đăng nhập</h3>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        @using (Html.BeginForm("DangNhapNguoiBan", "TaiKhoan", FormMethod.Post, new { id = "loginForm" }))
                        {
                            @Html.AntiForgeryToken()
                            <div class="mb-3">
                                <input type="text" name="TaiKhoan" class="form-control"
                                       placeholder="Tên đăng nhập" required />
                            </div>

                            <div class="mb-4 position-relative">
                                <input type="password" name="MatKhau" id="passwordInput"
                                       class="form-control" placeholder="Mật khẩu" required />
                                <span id="togglePassword" class="toggle-password">︶</span>
                            </div>

                            <div class="d-flex justify-content-end mb-4">
                                <a href="@Url.Action("QuenMatKhau", "TaiKhoan")"
                                   style="text-decoration:none;color:#0055AA;font-size:12px;">
                                    Quên mật khẩu?
                                </a>
                            </div>

                            <button type="submit" class="btn btn-next" id="btnLogin">
                                <span id="btnText">ĐĂNG NHẬP</span>
                                <span class="spinner-border spinner-border-sm ms-2 d-none" id="loginSpinner"></span>
                            </button>

                        }
                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">DỊCH VỤ KHÁCH HÀNG</h6>
                    <a href="#">Trung tâm trợ giúp</a>
                    <a href="#">Hướng dẫn mua hàng</a>
                    <a href="#">Trả hàng & hoàn tiền</a>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">SHOPEE VIỆT NAM</h6>
                    <a href="#">Giới thiệu</a>
                    <a href="#">Tuyển dụng</a>
                    <a href="#">Chính sách bảo mật</a>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">THANH TOÁN</h6>
                    <a href="#">COD</a>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <h6 class="fw-bold mb-3">THEO DÕI SHOPEE</h6>
                    <a href="#">Facebook</a>
                </div>
            </div>
        </div>
    </footer>

    <div class="footer-bottom">
        <span>© 2025 Shopee. Tất cả các quyền được bảo lưu.</span>
        <span>
            Quốc gia & Khu vực:
            <span class="footer-locations">
                <span>Singapore</span>
                <span>Indonesia</span>
                <span>Thái Lan</span>
                <span>Việt Nam</span>
            </span>
        </span>
    </div>

    <script>
        // Toggle password
        const passwordInput = document.getElementById("passwordInput");
        const togglePassword = document.getElementById("togglePassword");

        togglePassword.addEventListener("click", function () {
            const isPassword = passwordInput.type === "password";
            passwordInput.type = isPassword ? "text" : "password";
            togglePassword.textContent = isPassword ? "👁️" : "︶";
        });

        // HIỆU ỨNG LOADING KHI SUBMIT
        const form = document.getElementById("loginForm");
        const btn = document.getElementById("btnLogin");
        const spinner = document.getElementById("loginSpinner");
        const btnText = document.getElementById("btnText");

        form.addEventListener("submit", function () {
            btn.disabled = true;
            spinner.classList.remove("d-none");
            btnText.textContent = "ĐANG XỬ LÝ...";
        });
    </script>

</body>
</html>