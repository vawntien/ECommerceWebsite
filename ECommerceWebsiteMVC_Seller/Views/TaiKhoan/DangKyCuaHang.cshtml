@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shopee - Đăng ký cửa hàng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        /* ================== SELLER REGISTER PAGE ONLY ================== */
        .seller-register-page {
            background-color: #f5f5f5;
            font-family: -apple-system, Helvetica Neue, Helvetica, Roboto, Arial, sans-serif;
            min-height: 100vh;
        }

        .seller-register-header {
            background: #fff;
            padding: 15px 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.05);
            margin-bottom: 30px;
        }

        .seller-register-title {
            font-size: 22px;
            color: #ee4d2d;
            font-weight: 600;
            margin-left: 15px;
            padding-left: 15px;
            border-left: 1px solid #ddd;
        }

        .seller-register-form {
            max-width: 650px;
            margin: 0 auto;
            background: #fff;
            padding: 40px;
            border-radius: 4px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
        }

        .seller-register-label {
            font-weight: 500;
            color: #333;
        }

        .seller-register-btn {
            background: #ee4d2d;
            color: #fff;
            width: 100%;
            height: 48px;
            border: none;
            font-size: 16px;
            font-weight: 600;
            border-radius: 2px;
            transition: background 0.2s;
        }

            .seller-register-btn:hover {
                background: #d73211;
                color: #fff;
            }
    </style>
</head>

<body>
    <div class="seller-register-page">

        <!-- HEADER -->
        <div class="seller-register-header">
            <div class="container d-flex align-items-center">
                <a href="/">
                    <img src="~/assets/brand1.png" height="42" />
                </a>
                <span class="seller-register-title">
                    Đăng ký Cửa hàng
                </span>
            </div>
        </div>

        <!-- FORM -->
        <div class="container pb-5">
            <div class="seller-register-form">
                <h4 class="fw-bold mb-3">Thông tin cửa hàng</h4>
                <p class="text-muted mb-4">
                    Vui lòng cung cấp thông tin để bắt đầu bán hàng trên hệ thống.
                </p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        @ViewBag.Error
                    </div>
                }

                @using (Html.BeginForm("DangKyCuaHang", "TaiKhoan", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="seller-register-label">Tên cửa hàng <span class="text-danger">*</span></label>
                        <input type="text"
                               name="TenCuaHang"
                               class="form-control form-control-lg"
                               placeholder="Nhập tên cửa hàng"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="seller-register-label">Địa chỉ cửa hàng</label>
                        <input type="text"
                               name="DiaChi"
                               class="form-control"
                               placeholder="Nhập địa chỉ cửa hàng" />
                    </div>

                    <div class="mb-4">
                        <label class="seller-register-label">Mã số thuế </label>
                        <input type="text"
                               name="MaSoThue"
                               class="form-control"
                               placeholder="Nhập mã số thuế" />
                    </div>

                    <button type="submit" class="seller-register-btn">
                        HOÀN TẤT ĐĂNG KÝ CỬA HÀNG
                    </button>

                    <div class="text-center mt-4">
                        <a href="@Url.Action("DangNhapNguoiBan","TaiKhoan")"
                           class="text-secondary text-decoration-none small">
                            <i class="fa-solid fa-arrow-left-long me-1"></i>
                            Quay lại đăng nhập
                        </a>
                    </div>
                }
            </div>
        </div>

    </div>
</body>
</html>
