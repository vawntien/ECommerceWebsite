@model ECommerceWebsiteMVC_Seller.Models.NguoiBan
@{
    ViewBag.Title = "Hồ Sơ Người Bán";
    Layout = "~/Views/Shared/_LayoutNguoiBan.cshtml";
}

<style>
    .profile-body {
        background: #f5f5f5;
        padding-top: 30px;
        padding-bottom: 50px;
        min-height: 100vh;
    }

    .profile-card {
        background: #fff;
        max-width: 800px;
        margin: 0 auto;
        padding: 40px;
        border-radius: 4px;
        box-shadow: 0 1px 12px rgba(0,0,0,0.05);
    }

    /* NÚT QUAY LẠI MỚI - ĐẸP HƠN */
    .btn-back-home {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        color: #666;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 25px;
        padding: 8px 16px;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 20px;
        transition: all 0.3s ease;
    }

        .btn-back-home i {
            margin-right: 8px;
            transition: transform 0.3s ease;
        }

        .btn-back-home:hover {
            color: #ee4d2d;
            border-color: #ee4d2d;
            background-color: rgba(238, 77, 45, 0.05);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

            .btn-back-home:hover i {
                transform: translateX(-4px); /* Hiệu ứng mũi tên trượt sang trái */
            }

    .profile-header {
        border-bottom: 1px solid #efefef;
        padding-bottom: 20px;
        margin-bottom: 30px;
    }

    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
    }

    .label-col {
        width: 25%;
        text-align: right;
        padding-right: 25px;
        color: #555;
        font-size: 14px;
    }

    .input-col {
        width: 75%;
    }

    .shopee-input {
        width: 100%;
        max-width: 450px;
        height: 45px;
        padding: 12px;
        border: 1px solid #dbdbdb;
        border-radius: 4px;
        outline: none;
        font-size: 15px;
        transition: border-color 0.2s;
    }

        .shopee-input:focus {
            border-color: #ee4d2d;
            box-shadow: 0 0 0 2px rgba(238, 77, 45, 0.1);
        }

        .shopee-input[readonly] {
            background-color: #fafafa;
            color: #888;
            border-style: dashed;
        }

    .btn-save {
        background: #ee4d2d;
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 15px;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-save:hover {
            background: #d73211;
        }

        .btn-save:disabled {
            background: #ff8b72;
            cursor: not-allowed;
        }
</style>

<div class="profile-body">
    <div class="profile-card">
        <a href="@Url.Action("Index", "NguoiBan")" class="btn-back-home">
            <i class="fa-solid fa-arrow-left"></i> Quay lại trang quản trị
        </a>

        <div class="profile-header">
            <h3 class="m-0 fw-bold" style="color: #333;">Hồ Sơ Của Tôi</h3>
            <p class="text-muted small mt-2">Quản lý thông tin hồ sơ để bảo mật tài khoản và tăng độ tin cậy cho Shop</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 py-3 mb-4" style="background-color: #e6fffa; color: #2d3748; border-left: 4px solid #38a169;">
                <i class="fa-solid fa-circle-check me-2" style="color: #38a169;"></i> @TempData["Success"]
            </div>
        }

        @using (Html.BeginForm("HoSoNguoiBan", "TaiKhoan", FormMethod.Post, new { id = "sellerProfileForm" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-row">
                <div class="label-col">Tên đăng nhập</div>
                <div class="input-col">
                    <span class="fw-bold" style="font-size: 16px; color: #333;">@Model.TaiKhoan</span>
                </div>
            </div>

            <div class="form-row">
                <div class="label-col">Họ và Tên</div>
                <div class="input-col">
                    <input type="text" name="HoVaTen" class="shopee-input" value="@Model.HoVaTen" required />
                </div>
            </div>

            <div class="form-row">
                <div class="label-col">Email</div>
                <div class="input-col">
                    <input type="email" name="Email" class="shopee-input" value="@Model.Email" required />
                </div>
            </div>

            <div class="form-row">
                <div class="label-col">Số điện thoại</div>
                <div class="input-col">
                    <input type="text" name="SDT" class="shopee-input" value="@Model.SDT" required />
                </div>
            </div>

            <div class="form-row">
                <div class="label-col">Số CCCD</div>
                <div class="input-col">
                    <input type="text" class="shopee-input" value="@Model.CCCD" readonly title="Không thể thay đổi" />
                    <div class="form-text text-muted mt-2" style="font-size: 12px;">
                        <i class="fa-solid fa-circle-info me-1"></i> Số định danh cá nhân không thể tự thay đổi sau khi đã xác thực.
                    </div>
                </div>
            </div>

            <div class="form-row mt-5">
                <div class="label-col"></div>
                <div class="input-col">
                    <button type="submit" class="btn-save" id="btnSubmit">
                        <span id="txt">Lưu thay đổi</span>
                        <span id="load" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById("sellerProfileForm").onsubmit = function () {
        const btn = document.getElementById("btnSubmit");
        const txt = document.getElementById("txt");
        const load = document.getElementById("load");

        btn.disabled = true;
        txt.innerText = "Đang lưu...";
        load.classList.remove("d-none");
    };
</script>