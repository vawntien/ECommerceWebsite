@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shopee - Đặt lại mật khẩu Kênh Người Bán</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .reset-page {
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            background: #fff;
        }

            /* HEADER */
            .reset-page .top-header {
                background: #fff;
                padding: 12px 0;
                box-shadow: 0 1px 2px rgba(0,0,0,.05);
            }

            /* HERO SECTION */
            .reset-page .hero {
                background: #ee4d2d;
                padding: 80px 0;
            }

            .reset-page .hero-left {
                text-align: center;
                padding: 40px 20px;
                color: #fff;
            }

                .reset-page .hero-left img {
                    width: 160px;
                }

            /* FORM BOX */
            .reset-page .login-box {
                background: #fff;
                border-radius: 4px;
                padding: 40px;
                width: 100%;
                max-width: 450px;
                box-shadow: 0 12px 30px rgba(0,0,0,.16);
            }

            .reset-page .btn-submit {
                background: #ee4d2d;
                color: #fff;
                border: none;
                height: 50px;
                font-size: 16px;
                font-weight: 500;
                text-transform: uppercase;
                border-radius: 2px;
            }

                .reset-page .btn-submit:hover {
                    background: #c5311d;
                }

                .reset-page .btn-submit:disabled {
                    opacity: 0.8;
                }

            /* FOOTER */
            .reset-page .footer-bottom {
                background: #fff;
                border-top: 1px solid #ddd;
                padding: 40px 0;
                font-size: 13px;
                color: rgba(0,0,0,.54);
                text-align: center;
            }
    </style>
</head>

<body class="reset-page">

    <header class="top-header">
        <div class="container d-flex align-items-center">
            <a href="@Url.Action("Index", "NguoiBan")" style="text-decoration:none; display:flex; align-items:center;">
                <img src="~/assets/brand1.png" height="42" />
                <span style="font-size:22px;color:#ee4d2d;font-weight:700;margin-left:5px;margin-right:20px;">
                    Shopee
                </span>
            </a>
            <span style="font-size:20px;border-left:1px solid #ccc;padding-left:15px;">
                Thiết lập mật khẩu mới
            </span>
        </div>
    </header>

    <section class="hero">
        <div class="container">
            <div class="row align-items-center">

                <div class="col-lg-6 d-none d-lg-block hero-left">
                    <img src="~/assets/shope.png" />
                    <div class="mt-4 fs-3">Quản lý Shop chuyên nghiệp</div>
                    <div class="fs-5 fw-light">Cập nhật mật khẩu để bảo vệ tài khoản của bạn</div>
                </div>

                <div class="col-lg-6 d-flex justify-content-center">
                    <div class="login-box">
                        <h3 class="mb-4 fw-normal">Đặt lại mật khẩu</h3>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger" style="font-size:14px;background:#fff9fa;border:none;color:#ff424f;">
                                <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
                            </div>
                        }

                        @using (Html.BeginForm("DatLaiMatKhau", "TaiKhoan", FormMethod.Post, new { id = "resetForm" }))
                        {
                            @Html.AntiForgeryToken()

                            <div class="mb-3 position-relative">
                                <input type="password" name="MatKhauMoi" id="MatKhauMoi"
                                       class="form-control shadow-none"
                                       placeholder="Mật khẩu mới" required minlength="6" />
                            </div>

                            <div class="mb-4 position-relative">
                                <input type="password" name="XacNhanMatKhau" id="XacNhanMatKhau"
                                       class="form-control shadow-none"
                                       placeholder="Xác nhận mật khẩu mới" required />
                                <div id="msgMatch" class="form-text text-danger d-none" style="font-size: 12px;">
                                    Mật khẩu xác nhận không khớp!
                                </div>
                            </div>

                            <button type="submit" class="btn btn-submit w-100" id="btnAction">
                                <span id="btnText">XÁC NHẬN</span>
                                <span class="spinner-border spinner-border-sm ms-2 d-none" id="loadingSpinner"></span>
                            </button>
                        }
                    </div>
                </div>

            </div>
        </div>
    </section>

    <div class="footer-bottom">
        <div class="container">
            <span>© 2025 Shopee Kênh Người Bán. Tất cả các quyền được bảo lưu.</span>
        </div>
    </div>

    <script>
        const form = document.getElementById("resetForm");
        const btn = document.getElementById("btnAction");
        const pass = document.getElementById("MatKhauMoi");
        const confirmPass = document.getElementById("XacNhanMatKhau");
        const msg = document.getElementById("msgMatch");

        // Kiểm tra khớp mật khẩu khi gõ
        confirmPass.addEventListener("input", function() {
            if (confirmPass.value !== pass.value) {
                msg.classList.remove("d-none");
            } else {
                msg.classList.add("d-none");
            }
        });

        // Hiệu ứng Loading
        form.addEventListener("submit", function (e) {
            if (confirmPass.value !== pass.value) {
                e.preventDefault();
                msg.classList.remove("d-none");
                return;
            }

            btn.disabled = true;
            document.getElementById("loadingSpinner").classList.remove("d-none");
            document.getElementById("btnText").textContent = "ĐANG CẬP NHẬT...";
        });


       @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                title: 'Thành công!',
                html: '@Html.Raw(TempData["Success"])',
                icon: 'success',
                confirmButtonColor: '#ee4d2d',
                confirmButtonText: 'Đăng nhập ngay'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("DangNhapNguoiBan", "TaiKhoan")';
                }
            });
            </text>
        }
    </script>

</body>
</html>