@model ECommerceWebsiteMVC.Models.DanhGiaSanPham

@{
    Layout = null;
    // Ảnh sản phẩm mặc định
    var macdinh = Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.AnhSanPhams
        .Where(x => x.MacDinh == true)
        .Select(x => x.HinhAnh)
        .FirstOrDefault()
        ?? Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.AnhSanPhams
            .Select(x => x.HinhAnh)
            .FirstOrDefault();

    // Ảnh đánh giá cũ (nếu đang chỉnh sửa)
    var hasReviewImage = !string.IsNullOrEmpty(Model.HinhAnh);
    var reviewImageUrl = hasReviewImage
        ? $"https://ecommerceshopstorage.blob.core.windows.net/reviews/{Model.HinhAnh}"
        : "";
}

<!-- Fonts + Icons + Tailwind -->
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<script>
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    primaryColor: "#f97316",
                    "background-light": "#f8fafc",
                    "background-dark": "#0f172a",
                },
                fontFamily: {
                    display: ["Roboto", "sans-serif"],
                },
                borderRadius: {
                    DEFAULT: "0.25rem",
                },
            },
        },
    };
</script>

<style>
    /* Reset Bootstrap conflicts */
    #product-review-modal * {
        box-sizing: border-box;
    }

    #product-review-modal input[type="text"],
    #product-review-modal textarea {
        width: 100% !important;
        max-width: 100% !important;
    }

    .star-rating {
        display: inline-flex;
        gap: 0.25rem;
    }

    .star-rating .material-icons {
        font-size: 1.75rem;
        color: #f59e0b;
        cursor: pointer;
        user-select: none;
    }

    /* Custom layout cho form fields */
    .review-form-field {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
    }

    .review-form-field.horizontal {
        display: grid;
        grid-template-columns: 160px 1fr;
        align-items: center;
        gap: 1rem;
    }

    .review-form-field.textarea-field {
        display: grid;
        grid-template-columns: 160px 1fr;
        align-items: start;
        gap: 1rem;
    }

   

    .review-input-wrapper {
        width: 100%;
    }

    .review-input-wrapper input,
    .review-input-wrapper textarea {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        background-color: white;
    }

    .dark .review-input-wrapper input,
    .dark .review-input-wrapper textarea {
        background-color: #1e293b;
        border-color: #475569;
        color: #e5e7eb;
    }

    .review-input-wrapper input:focus,
    .review-input-wrapper textarea:focus {
        outline: none;
        border-color: #f97316;
        box-shadow: 0 0 0 1px #f97316;
    }

    .review-input-wrapper textarea {
        height: 128px;
        resize: vertical;
    }
    .review-distance-header{
        margin-top: 200px;
    }
</style>

<!-- OVERLAY MODAL -->
<div id="product-review-modal-@Model.ChiTietDonHang.MaCTDH" data-review-modal
     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 hidden">

    <div class="max-w-4xl w-full mx-4 md:mx-auto">
        <div class="review-distance-header bg-white dark:bg-slate-800 p-6 md:p-8 rounded-lg shadow-lg relative
                    font-display text-gray-800 dark:text-gray-200">

            @using (Html.BeginForm("ThemDanhGia", "DanhGia", FormMethod.Post,
                   new { enctype = "multipart/form-data", id = "product-review-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("ReturnUrl", Request?.Url?.AbsoluteUri)
                <!-- nút đóng -->
                <button type="button"
                        class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"
                        data-close-review-modal>
                    <span class="material-icons">close</span>
                </button>

                <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
                    Đánh Giá Sản Phẩm
                </h1>

                @Html.HiddenFor(m => m.MaCTDH)

                <!-- THÔNG TIN SẢN PHẨM -->
                <div class="flex items-start gap-4 pb-6 border-b border-gray-200 dark:border-gray-700">
                    <img alt="Ảnh sản phẩm"
                         class="w-12 h-12 object-cover rounded"
                         src="@($"https://ecommerceshopstorage.blob.core.windows.net/products/{Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.MaSanPham}/{macdinh}")" />
                    <div>
                        <h2 class="font-medium text-gray-900 dark:text-white">
                            @Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.TenSanPham
                        </h2>
                    </div>
                </div>

                

                <!-- CHẤT LƯỢNG + TIÊU ĐỀ -->
                <input type="hidden"
                       id="SoSao"
                       name="SoSao"
                       value="@(Model?.SoSao > 0 ? Model.SoSao : 5)" />

                <div class="py-6 space-y-4">

                    <!-- Chất lượng sản phẩm -->
                    <div class="flex flex-wrap items-center gap-4">
                        <span class="text-gray-700 dark:text-gray-300">Chất lượng sản phẩm</span>

                        <div class="flex items-center gap-2">
                            <div class="star-rating" id="review-stars">
                                <span class="material-icons" data-value="1">star</span>
                                <span class="material-icons" data-value="2">star</span>
                                <span class="material-icons" data-value="3">star</span>
                                <span class="material-icons" data-value="4">star</span>
                                <span class="material-icons" data-value="5">star</span>
                            </div>
                            <span id="rating-text" class="text-amber-500 font-medium">Tuyệt vời</span>
                        </div>
                    </div>

                    <!-- Tiêu đề -->
                    <div class="review-form-field horizontal">
                        <span class="text-gray-700 dark:text-gray-300">Tiêu đề</span>
                        <div class="review-input-wrapper">
                            <input type="text"
                                   name="TieuDe"
                                   placeholder="VD: Sản phẩm rất tốt, đáng mua"
                                   value="@(Model?.TieuDe ?? "")" />
                        </div>
                    </div>

                </div>

                <!-- NỘI DUNG + ẢNH -->
                <div class="p-2 border border-gray-200 dark:border-gray-700 rounded bg-gray-50 dark:bg-slate-700/50">

                    <!-- Nội dung -->
                    <div class="review-form-field textarea-field">
                        <span class="text-gray-700 dark:text-gray-300">Nội dung</span>
                        <div class="review-input-wrapper">
                            <textarea name="NoiDung"
                                      placeholder="Hãy chia sẻ những điều bạn thích / chưa hài lòng về sản phẩm…">@(Model?.NoiDung ?? "")</textarea>
                        </div>
                    </div>

                    <!-- Upload + Preview -->
                    <div class="mt-sm-2 flex flex-col gap-3">

                        <div class="flex flex-wrap items-center gap-4">
                            <input type="file"
                                   id="HinhAnhFile"
                                   name="HinhAnhFile"
                                   class="hidden"
                                   accept="image/*" />

                            <button type="button"
                                    class="flex items-center gap-2 px-4 py-2 text-primaryColor rounded
                                           text-sm font-medium hover:bg-primaryColor/10 transition-colors"
                                    style="border: 1px solid #f97316;"
                                    onclick="document.getElementById('HinhAnhFile').click();">
                                <span class="material-icons" style="font-size: 1.25rem;">photo_camera</span>
                                Thêm Hình ảnh
                            </button>
                        </div>

                        <!-- Preview -->
                        <div id="review-image-preview-wrapper"
                             class="flex items-start gap-3 @(hasReviewImage ? "" : "hidden")">

                            <img id="review-image-preview"
                                 src="@(hasReviewImage ? reviewImageUrl : "")"
                                 class="w-24 h-24 rounded-lg object-cover border border-gray-300 dark:border-gray-600 shadow-sm" />

                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="mt-sm-1 bg-white dark:bg-slate-800 p-sm-1 rounded-lg flex items-center justify-between">
                    <div></div>

                    <div class="flex items-center gap-5">
                        <button type="button"
                                class="px-6 py-2.5 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700
                                       rounded font-medium transition-colors"
                                data-close-review-modal>
                            TRỞ LẠI
                        </button>

                        <button type="submit"
                                class="px-8 py-2.5 bg-primaryColor text-white rounded font-medium hover:bg-orange-600 transition-colors">
                            HOÀN THÀNH
                        </button>
                        @*<a href="@Url.Action("ChiTietDonHang", "NguoiMua", new { id = Model.ChiTietDonHang.MaDonHang })"
                       type="submit"
                       class="px-8 py-2.5 bg-primaryColor text-white rounded font-medium hover:bg-orange-600 transition-colors">
                        HOÀN THÀNH
                    </a>*@
                    </div>
                </div>

            }
        </div>
    </div>
</div>

<!-- JS -->
<script>
    // mở modal (gọi từ view cha)
    window.openReviewModal = function (maCTDH) {
        var modal = document.getElementById('product-review-modal-' + maCTDH);
        if (modal) modal.classList.remove('hidden');
    };


    // đóng modal
    document.addEventListener('click', function (e) {

        // nút đóng
        if (e.target.closest('[data-close-review-modal]')) {
            var modal = e.target.closest('[data-review-modal]');
            if (modal) modal.classList.add('hidden');
        }

        // click nền đen
        if (e.target.hasAttribute('data-review-modal')) {
            e.target.classList.add('hidden');
        }
    });


    // JS chọn sao
    document.addEventListener('DOMContentLoaded', function () {
        var starsContainer = document.getElementById('review-stars');
        var hiddenInput = document.getElementById('SoSao');
        var ratingText = document.getElementById('rating-text');
        var labels = ["", "Tệ", "Tạm ổn", "Khá", "Tốt", "Tuyệt vời"];

        if (starsContainer && hiddenInput) {
            var stars = starsContainer.querySelectorAll('.material-icons');

            function render(value) {
                stars.forEach(function (s) {
                    var v = parseInt(s.getAttribute('data-value'));
                    s.textContent = v <= value ? 'star' : 'star_border';
                });
                if (ratingText) ratingText.textContent = labels[value] || "";
            }

            stars.forEach(function (s) {
                s.addEventListener('click', function () {
                    var v = parseInt(this.getAttribute('data-value')) || 0;
                    hiddenInput.value = v;
                    render(v);
                });
            });

            var initial = parseInt(hiddenInput.value) || 5;
            render(initial);
        }

        // Preview ảnh upload
        var fileInput = document.getElementById('HinhAnhFile');
        var previewWrapper = document.getElementById('review-image-preview-wrapper');
        var previewImg = document.getElementById('review-image-preview');

        if (fileInput && previewWrapper && previewImg) {
            fileInput.addEventListener('change', function () {
                if (this.files && this.files.length > 0) {
                    var file = this.files[0];
                    var url = URL.createObjectURL(file);

                    previewImg.src = url;
                    previewWrapper.classList.remove('hidden');
                } else {
                    previewImg.src = "";
                    previewWrapper.classList.add('hidden');
                }
            });
        }
    });
</script>