@model ECommerceWebsiteMVC.Models.CheckoutViewModel

@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_LayoutNguoiMua.cshtml";
}

<style>
    body {
        background: #f5f5f5;
        font-family: Arial, sans-serif;
    }

    .checkout-container {
        max-width: 900px;
        margin: 130px auto 120px auto;
        background: #fff;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .section-title {
        font-weight: bold;
        font-size: 18px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 1px solid #eee;
    }

    .item-row {
        display: grid;
        grid-template-columns: 15% 55% 15% 15%;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        align-items: center;
        font-size: 14px;
    }

        .item-row img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 4px;
        }

    .total-box {
        width: 350px;
        margin-top: 20px;
        margin-left: auto;
        font-size: 15px;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        margin: 6px 0;
    }

    .confirm-button {
        background: #ee4d2d;
        padding: 12px 24px;
        width: 100%;
        border: none;
        color: white;
        font-weight: bold;
        cursor: pointer;
        margin-top: 16px;
        border-radius: 4px;
        font-size: 16px;
    }
</style>

<style>
    #popup-address {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        z-index: 9999;
        display: none;
        justify-content: center;
        align-items: center;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .shopee-popup {
        background: #fff;
        width: 550px;
        border-radius: 4px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .popup-header {
        padding: 20px 24px;
        font-size: 1.125rem;
        color: #000;
        border-bottom: 1px solid #e8e8e8;
        font-weight: 500;
    }

    .address-list-body {
        padding: 0 24px;
        overflow-y: auto;
        flex: 1;
        background-color: #fff;
    }

    .addr-item {
        display: flex;
        padding: 20px 0;
        border-bottom: 1px solid #e8e8e8;
        align-items: flex-start;
    }

    .addr-radio-col {
        padding-right: 16px;
        display: flex;
        align-items: center;
        padding-top: 4px;
    }

    .addr-radio {
        width: 18px;
        height: 18px;
        accent-color: #ee4d2d;
        cursor: pointer;
    }

    .addr-content-col {
        flex: 1;
    }

    .addr-top-row {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
        justify-content: space-between;
    }

    .addr-name-phone {
        display: flex;
        align-items: center;
        color: #000;
        font-size: 1rem;
    }

    .addr-name {
        font-weight: 600;
        padding-right: 8px;
        border-right: 1px solid #e8e8e8;
        margin-right: 8px;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .addr-phone {
        color: #888;
        font-size: 0.875rem;
    }

    .btn-update {
        color: #0055aa;
        font-size: 0.875rem;
        cursor: pointer;
        text-decoration: none;
        border: none;
        background: none;
        font-weight: 500;
    }

        .btn-update:hover {
            color: #ee4d2d;
        }

    .addr-detail {
        color: #555;
        font-size: 0.875rem;
        line-height: 1.4;
        margin-bottom: 8px;
    }

    .addr-tags {
        display: flex;
        gap: 8px;
    }

    .tag-default {
        color: #ee4d2d;
        border: 1px solid #ee4d2d;
        font-size: 12px;
        padding: 2px 6px;
        border-radius: 2px;
    }

    /* Nút thêm mới và Footer */
    .btn-add-new-row {
        margin-top: 10px;
        margin-bottom: 20px;
    }

    .btn-add-new {
        background: #fff;
        border: 1px solid #e8e8e8;
        color: #555;
        height: 40px;
        width: 100%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

        .btn-add-new:hover {
            background: #f8f8f8;
            color: #ee4d2d;
            border-color: #ee4d2d;
        }

    .popup-footer {
        padding: 15px 24px;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        border-top: 1px solid #e8e8e8;
        background: #fff;
    }

    .btn-cancel {
        min-width: 140px;
        padding: 10px 0;
        border: none;
        background: #fff;
        color: #555;
        cursor: pointer;
        font-size: 14px;
    }

        .btn-cancel:hover {
            background: #f8f8f8;
        }

    .btn-confirm {
        min-width: 140px;
        padding: 10px 0;
        border: none;
        background: #ee4d2d;
        color: #fff;
        cursor: pointer;
        border-radius: 2px;
        font-size: 14px;
    }

        .btn-confirm:hover {
            background: #d73211;
        }

    /* Form thêm mới */
    .form-group {
        margin-bottom: 16px;
    }

    .input-shopee {
        width: 100%;
        padding: 10px;
        border: 1px solid #e8e8e8;
        border-radius: 2px;
        outline: none;
        box-sizing: border-box;
        font-size: 14px;
    }

        .input-shopee:focus {
            border-color: #777;
        }

    .form-row-2 {
        display: flex;
        gap: 16px;
    }

        .form-row-2 > * {
            flex: 1;
        }
</style>

<div class="checkout-container">

    <div class="section-title">
        Địa chỉ nhận hàng
        <button id="btn-open-address" style="margin-left:10px;padding:4px 10px;font-size:12px; background:#fff;border:1px solid #ee4d2d;color:#ee4d2d;border-radius:3px;cursor:pointer;">
            Thay Đổi
        </button>
    </div>

    <div id="address-display" style="margin-bottom:20px; font-size:14px;">
        <strong id="tennhan">@Model.TenNguoiNhan</strong><br />
        SĐT: <span id="sdtnhan">@Model.SDT</span><br />
        <span id="diachinhan">@Model.DiaChi</span>
    </div>

    <div class="section-title">Sản phẩm</div>
    @foreach (var item in Model.Items)
    {
        <div class="item-row">
           <img src="@($"https://ecommerceshopstorage.blob.core.windows.net/variants/{item.HinhAnh}")" />
            <div>
                <div style="font-weight:bold;">@item.TenSanPham</div>
                <div style="color:#888;">@item.PhanLoai</div>
            </div>
            <div style="color:#ee4d2d;">@item.DonGia.ToString("N0") đ</div>
            <div>x @item.SoLuong</div>
        </div>
    }

    <div class="section-title" style="margin-top:20px;">Shopee Voucher</div>
    <div style="display:flex;align-items:center;">
        <select id="voucherSelect" style="width:300px;padding:6px;border:1px solid #ddd;border-radius:4px;">
            <option value="">-- Không dùng voucher --</option>
            @foreach (var vc in Model.DanhSachVoucher)
            {
                var g = Convert.ToDecimal(vc.GiaTriGiam);
                <option value="@vc.MaGiamGia">
                    @vc.TenMaGG - Giảm @g.ToString("N0")đ
                </option>
            }
        </select>
        <button id="applyVoucher" type="button" style="margin-left:10px;padding:6px 14px;background:#ee4d2d;color:white;border:none;border-radius:4px;cursor:pointer;">
            Áp dụng
        </button>
    </div>

    <div class="total-box">
        <div class="total-row">
            <span>Tổng tiền hàng:</span>
            <span id="tien-hang" data-raw="@Convert.ToInt64(Model.TongTienHang)">
                @Model.TongTienHang.ToString("N0") đ
            </span>
        </div>
        <div class="total-row">
            <span>Phí vận chuyển:</span>
            <span id="phi-ship" data-raw="@Convert.ToInt64(Model.PhiVanChuyen)">
                @Model.PhiVanChuyen.ToString("N0") đ
            </span>
        </div>
        <div class="total-row">
            <span>Giảm giá:</span>
            <span id="giam-gia" data-raw="@Convert.ToInt64(Model.GiamGia)">
                @Model.GiamGia.ToString("N0") đ
            </span>
        </div>
        <div class="total-row" style="font-weight:bold;font-size:18px;">
            <span>Tổng thanh toán:</span>
            <span id="tong-thanh-toan" data-raw="@Convert.ToInt64(Model.TongThanhToan)" style="color:#ee4d2d;">
                @Model.TongThanhToan.ToString("N0") đ
            </span>
        </div>
    </div>

    <form id="form-checkout" action="/GioHang/OrderSuccess" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="NguoiNhan" id="hidden-ten" value="@Model.TenNguoiNhan" />
        <input type="hidden" name="SDT" id="hidden-sdt" value="@Model.SDT" />
        <input type="hidden" name="DiaChi" id="hidden-diachi" value="@Model.DiaChi" />
        <input type="hidden" name="MaVoucher" id="voucherHidden" />
        <button type="submit" class="confirm-button">Đặt hàng</button>
    </form>
</div>

<div id="popup-address">
    <div class="shopee-popup">

        <div id="view-list" style="display:flex; flex-direction:column; height:100%;">
            <div class="popup-header">Địa Chỉ Của Tôi</div>

            <div class="address-list-body">
                <div id="address-list-container"></div>

                <div class="btn-add-new-row">
                    <button id="btn-show-add-form" class="btn-add-new">
                        + Thêm Địa Chỉ Mới
                    </button>
                </div>
            </div>

            <div class="popup-footer">
                <button class="btn-cancel" id="btn-close-popup">Huỷ</button>
                <button class="btn-confirm" id="btn-confirm-selection">Xác nhận</button>
            </div>
        </div>

        <div id="view-form" style="display:none; flex-direction:column; height:100%;">
            <div class="popup-header">Địa chỉ mới</div>

            <div class="address-list-body" style="padding-top: 20px;">
                <div class="form-row-2 form-group">
                    <input id="new-name" class="input-shopee" placeholder="Họ và tên" />
                   <input id="new-phone" 
                   class="input-shopee" 
                   placeholder="Số điện thoại" 
                   type="tel"
                   maxlength="10" 
                   pattern="0[0-9]{9}" 
                   title="SĐT phải bắt đầu bằng 0 và có 10 số" 
                   required />
                </div>

                <div class="form-group">
                    <input id="new-city" class="input-shopee" placeholder="Tỉnh/Thành phố, Quận/Huyện, Phường/Xã, Số nhà..." />
                </div>
            </div>

            <div class="popup-footer">
                <button class="btn-cancel" id="btn-back-to-list">Trở Lại</button>
                <button class="btn-confirm" id="btn-save-new">Hoàn thành</button>
            </div>
        </div>

    </div>
</div>

@section scripts {
    <script>
        // ===== LOGIC VOUCHER =====
        function getMoney(selector) {
            let raw = $(selector).attr("data-raw");
            return parseInt(raw) || 0;
        }

        $(document).on("click", "#applyVoucher", function () {
            var maVoucher = $("#voucherSelect").val();
            var tongTienHang = getMoney("#tien-hang");

            $.ajax({
                url: "/GioHang/ApplyVoucher",
                type: "POST",
                data: { maVoucher: maVoucher, tongTienHang: tongTienHang },
                success: function (res) {
                    if (!res.success) {
                        alert(res.message || "Voucher không hợp lệ!");
                        return;
                    }
                    $("#giam-gia")
                        .attr("data-raw", res.giamGia)
                        .text(res.giamGia.toLocaleString("vi-VN") + " đ");
                    $("#tong-thanh-toan")
                        .attr("data-raw", res.tongThanhToan)
                        .text(res.tongThanhToan.toLocaleString("vi-VN") + " đ");
                    $("#voucherHidden").val(maVoucher);
                },
                error: function () {
                    alert("Lỗi kết nối server!");
                }
            });
        });

        // ===============================================
        // ===== LOGIC ĐỊA CHỈ (ĐÃ CẬP NHẬT) =====
        // ===============================================

        // 1. Mở popup
        $(document).on("click", "#btn-open-address", function (e) {
            e.preventDefault();
            $("#popup-address").css("display", "flex");
            $("#view-list").show();
            $("#view-form").hide();
            loadAddressHistory();
        });

        // Gọi Ajax lấy lịch sử
        function loadAddressHistory() {
            $("#address-list-container").html('<div style="padding:20px;text-align:center;">Đang tải...</div>');
            $.get("/GioHang/GetDeliveryHistory", function (res) {
                if (res.success) {
                    renderAddressList(res.data);
                } else {
                    $("#address-list-container").html('<div style="padding:20px;text-align:center;">Lỗi tải dữ liệu</div>');
                }
            });
        }

        // Vẽ danh sách địa chỉ
        function renderAddressList(data) {
            var html = "";
            var currentName = $("#tennhan").text().trim();
            var currentPhone = $("#sdtnhan").text().trim();

            if (!data || data.length === 0) {
                html = '<div style="text-align:center; padding:30px; color:#888;">Bạn chưa có lịch sử địa chỉ.</div>';
            } else {
                data.forEach(function (item) {
                    var isChecked = (item.HoTen === currentName && item.SDT === currentPhone) ? "checked" : "";
                    if (data.length === 1) isChecked = "checked";

                    var tagsHtml = item.IsDefault ? `<span class="tag-default">Mặc định</span>` : "";

                    html += `
                        <div class="addr-item">
                            <div class="addr-radio-col">
                                <input type="radio" name="addr_radio" class="addr-radio" ${isChecked}
                                       data-name="${item.HoTen}" data-phone="${item.SDT}" data-addr="${item.DiaChi}">
                            </div>
                            <div class="addr-content-col">
                                <div class="addr-top-row">
                                    <div class="addr-name-phone">
                                        <span class="addr-name">${item.HoTen}</span>
                                        <span class="addr-phone">${item.SDT}</span>
                                    </div>
                                    <button class="btn-update" onclick="fillFormForUpdate('${item.HoTen}', '${item.SDT}', '${item.DiaChi}')">Cập nhật</button>
                                </div>
                                <div class="addr-detail">${item.DiaChi}</div>
                                <div class="addr-tags">${tagsHtml}</div>
                            </div>
                        </div>`;
                });
            }
            $("#address-list-container").html(html);
        }

        // Chuyển màn hình 
        $("#btn-show-add-form").click(function () {
            $("#view-list").hide(); $("#view-form").show();

            // Lấy thông tin Tên & SĐT đang hiển thị trên màn hình chính (Dữ liệu đã được gán)
            var currentName = $("#tennhan").text().trim();
            var currentPhone = $("#sdtnhan").text().trim();
            var currentAddr = $("#diachinhan").text().trim();

            // Tự động điền các ô input mới
            $("#new-name").val(currentName);
            $("#new-phone").val(currentPhone);
            $("#new-city").val(currentAddr);
        });

        $("#btn-back-to-list, #btn-close-popup").click(function () {
            if ($(this).attr("id") === "btn-close-popup") $("#popup-address").hide();
            else { $("#view-form").hide(); $("#view-list").show(); }
        });

        // Điền form để cập nhật (Chỉ dùng 1 ô địa chỉ)
        window.fillFormForUpdate = function (name, phone, addr) {
            $("#new-name").val(name);
            $("#new-phone").val(phone);
            $("#new-city").val(addr); // Điền toàn bộ địa chỉ vào ô này

            $("#view-list").hide();
            $("#view-form").show();
        };

        // Xác nhận chọn từ danh sách
        $("#btn-confirm-selection").click(function () {
            var selected = $("input[name='addr_radio']:checked");
            if (selected.length === 0) { alert("Vui lòng chọn địa chỉ!"); return; }
            applyAddress(selected.data("name"), selected.data("phone"), selected.data("addr"));
            $("#popup-address").hide();
        });

        // Nút Hoàn thành (Lưu mới) - Đã sửa bỏ Textarea
        $("#btn-save-new").click(function () {
            var ten = $("#new-name").val().trim();
            var sdt = $("#new-phone").val().trim();
            var fullAddr = $("#new-city").val().trim();

            if (ten === "" || sdt === "" || fullAddr === "") {
                alert("Vui lòng điền đủ thông tin!"); return;
            }

            // --- KIỂM TRA ĐỊNH DẠNG NGHIÊM NGẶT (NHƯ TRIGGER SQL) ---
            // Kiểm tra: Phải 10 số AND bắt đầu bằng 0 AND không chứa ký tự lạ
            if (sdt.length !== 10 || !sdt.startsWith("0") || sdt.match(/[^0-9]/)) {
                alert("Lỗi: Số điện thoại phải gồm 10 chữ số và bắt đầu bằng số 0!");
                $("#new-phone").focus();
                return;
            }
            // --------------------------------------------------------

            applyAddress(ten, sdt, fullAddr);
            $("#popup-address").hide();
        });

        // Hàm cập nhật ra màn hình chính
        function applyAddress(ten, sdt, diachi) {
            $("#tennhan").text(ten);
            $("#sdtnhan").text(sdt);
            $("#diachinhan").text(diachi);
            $("#hidden-ten").val(ten);
            $("#hidden-sdt").val(sdt);
            $("#hidden-diachi").val(diachi);
        }

        // ===============================================
        // ===== VALIDATE TRƯỚC KHI SUBMIT FORM (ĐÃ SỬA) =====
        // ===============================================
        $("#form-checkout").submit(function (e) {
            // Lấy giá trị từ các ô hidden
            var ten = $("#hidden-ten").val().trim();
            var sdt = $("#hidden-sdt").val().trim();
            var diachi = $("#hidden-diachi").val().trim();

            // Kiểm tra nếu thiếu 1 trong 3 thông tin
            if (ten === "" || sdt === "" || diachi === "") {
                e.preventDefault(); // <-- CHẶN gửi form

                alert("Bạn chưa nhập địa chỉ nhận hàng. Vui lòng thêm địa chỉ trước khi đặt hàng!");

                // 1. Mở Popup
                $("#popup-address").css("display", "flex");

                // 2. Chuyển thẳng sang FORM thêm mới (view-form) và ẩn danh sách lịch sử
                $("#view-list").hide();
                $("#view-form").show();

                // 3. Tự động điền thông tin cũ vào form
                var currentName = $("#tennhan").text().trim();
                var currentPhone = $("#sdtnhan").text().trim();
                var currentAddr = $("#diachinhan").text().trim();

                $("#new-name").val(currentName);
                $("#new-phone").val(currentPhone);

                // Điền địa chỉ đang thiếu vào ô nhập địa chỉ mới
                $("#new-city").val(currentAddr);
            }
            // Nếu thông tin đầy đủ, form sẽ gửi đi bình thường.
        });

    </script>
}