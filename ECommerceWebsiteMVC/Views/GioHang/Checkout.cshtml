@model ECommerceWebsiteMVC.Models.CheckoutViewModel

@{
    ViewBag.Title = "Thanh toán";
}

<style>
    body {
        background: #f5f5f5;
        font-family: Arial;
    }

    .checkout-container {
        max-width: 900px;
        margin: 20px auto 120px auto;
        background: #fff;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .section-title {
        font-weight: bold;
        font-size: 18px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 1px solid #eee;
    }

    .item-row {
        display: grid;
        grid-template-columns: 15% 55% 15% 15%;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        align-items: center;
        font-size: 14px;
    }

        .item-row img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 4px;
        }

    .total-box {
        width: 350px;
        margin-top: 20px;
        margin-left: auto;
        font-size: 15px;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        margin: 6px 0;
    }

    .confirm-button {
        background: #ee4d2d;
        padding: 12px 24px;
        width: 100%;
        border: none;
        color: white;
        font-weight: bold;
        cursor: pointer;
        margin-top: 16px;
        border-radius: 4px;
        font-size: 16px;
    }
</style>

<div class="checkout-container">

    <!-- ĐỊA CHỈ NHẬN HÀNG -->
    <div class="section-title">
        Địa chỉ nhận hàng
        <button id="btn-open-address"
                style="margin-left:10px;padding:4px 10px;font-size:12px;
            background:#fff;border:1px solid #ee4d2d;color:#ee4d2d;border-radius:3px;cursor:pointer;">
            Thay Đổi
        </button>
    </div>

    <div id="address-display" style="margin-bottom:20px; font-size:14px;">
        <strong id="tennhan">@Model.TenNguoiNhan</strong><br />
        SĐT: <span id="sdtnhan">@Model.SDT</span><br />
        <span id="diachinhan">@Model.DiaChi</span>
    </div>


    <!-- DANH SÁCH SẢN PHẨM -->
    <div class="section-title">Sản phẩm</div>

    @foreach (var item in Model.Items)
    {
        <div class="item-row">
            <img src="/assets/@item.HinhAnh" />
            <div>
                <div style="font-weight:bold;">@item.TenSanPham</div>
                <div style="color:#888;">@item.PhanLoai</div>
            </div>
            <div style="color:#ee4d2d;">@item.DonGia.ToString("N0") đ</div>
            <div>x @item.SoLuong</div>
        </div>
    }

    <!-- VOUCHER -->
    <div class="section-title" style="margin-top:20px;">Shopee Voucher</div>

    <div style="display:flex;align-items:center;">
        <select id="voucherSelect"
                style="width:300px;padding:6px;border:1px solid #ddd;border-radius:4px;">

            <option value="">-- Không dùng voucher --</option>

            @foreach (var vc in Model.DanhSachVoucher)
            {
                var g = Convert.ToDecimal(vc.GiaTriGiam);

                <option value="@vc.MaGiamGia">
                    @vc.TenMaGG - Giảm @g.ToString("N0")đ
                </option>
            }
        </select>

        <button id="applyVoucher"
                type="button"
                style="margin-left:10px;padding:6px 14px;background:#ee4d2d;color:white;border:none;border-radius:4px;cursor:pointer;">
            Áp dụng
        </button>
    </div>

    <!-- TÍNH TIỀN -->
    <div class="total-box">

        <div class="total-row">
            <span>Tổng tiền hàng:</span>
            <span id="tien-hang" data-raw="@Convert.ToInt64(Model.TongTienHang)">
                @Model.TongTienHang.ToString("N0") đ
            </span>
        </div>

        <div class="total-row">
            <span>Phí vận chuyển:</span>
            <span id="phi-ship" data-raw="@Convert.ToInt64(Model.PhiVanChuyen)">
                @Model.PhiVanChuyen.ToString("N0") đ
            </span>
        </div>

        <div class="total-row">
            <span>Giảm giá:</span>
            <span id="giam-gia" data-raw="@Convert.ToInt64(Model.GiamGia)">
                @Model.GiamGia.ToString("N0") đ
            </span>
        </div>

        <div class="total-row" style="font-weight:bold;font-size:18px;">
            <span>Tổng thanh toán:</span>
            <span id="tong-thanh-toan" data-raw="@Convert.ToInt64(Model.TongThanhToan)" style="color:#ee4d2d;">
                @Model.TongThanhToan.ToString("N0") đ
            </span>
        </div>
    </div>

    <form action="/GioHang/OrderSuccess" method="post">
        @Html.AntiForgeryToken()

        <!-- 3 hidden lưu thông tin người nhận -->
        <input type="hidden" name="NguoiNhan" id="hidden-ten" />
        <input type="hidden" name="SDT" id="hidden-sdt" />
        <input type="hidden" name="DiaChi" id="hidden-diachi" />

        <!-- hidden mã voucher (đã dùng từ trước) -->
        <input type="hidden" name="MaVoucher" id="voucherHidden" />

        <button type="submit" class="confirm-button">Đặt hàng</button>
    </form>

</div>


@section scripts {
    <script>

        // mở popup
        $(document).on("click", "#btn-open-address", function () {
            $("#popup-ten").val($("#tennhan").text());
            $("#popup-sdt").val($("#sdtnhan").text());
            $("#popup-diachi").val($("#diachinhan").text());

            $("#popup-address").css("display", "flex");
        });

        // đóng popup
        $(document).on("click", "#btn-cancel", function () {
            $("#popup-address").hide();
        });

        // lưu địa chỉ
        $(document).on("click", "#btn-save-address", function () {

            let ten = $("#popup-ten").val().trim();
            let sdt = $("#popup-sdt").val().trim();
            let diachi = $("#popup-diachi").val().trim();

            if (ten == "" || sdt == "" || diachi == "") {
                alert("Vui lòng nhập đầy đủ thông tin!");
                return;
            }

            // cập nhật hiển thị
            $("#tennhan").text(ten);
            $("#sdtnhan").text(sdt);
            $("#diachinhan").text(diachi);

            // gán vào hidden để submit
            $("#hidden-ten").val(ten);
            $("#hidden-sdt").val(sdt);
            $("#hidden-diachi").val(diachi);

            $("#popup-address").hide();
        });


        // ===== ĐỌC TIỀN SẠCH TỪ data-raw =====
        function getMoney(selector) {
            let raw = $(selector).attr("data-raw");
            return parseInt(raw) || 0;
        }

        $(document).on("click", "#applyVoucher", function () {

            var maVoucher = $("#voucherSelect").val();

            var tongTienHang = getMoney("#tien-hang");

            console.log("SEND:", maVoucher, tongTienHang);

            $.ajax({
                url: "/GioHang/ApplyVoucher",
                type: "POST",
                data: {
                    maVoucher: maVoucher,
                    tongTienHang: tongTienHang
                },
                success: function (res) {
                    if (!res.success) {
                        alert("Voucher không hợp lệ!");
                        return;
                    }

                    // Giảm giá
                    $("#giam-gia")
                        .attr("data-raw", res.giamGia)
                        .text(res.giamGia.toLocaleString("vi-VN") + " đ");

                    // Tổng thanh toán
                    $("#tong-thanh-toan")
                        .attr("data-raw", res.tongThanhToan)
                        .text(res.tongThanhToan.toLocaleString("vi-VN") + " đ");

                    // Lưu voucher
                    $("#voucherHidden").val(maVoucher);
                },
                error: function () {
                    alert("AJAX ERROR – Controller không chạy!");
                }
            });
        });
    </script>
}

<!-- POPUP ĐỊA CHỈ -->
<div id="popup-address"
     style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
            background:rgba(0,0,0,0.4); z-index:9999; justify-content:center; align-items:center;">

    <div style="background:white; width:500px; padding:20px; border-radius:6px;">

        <h3 style="margin-bottom:20px;">Cập nhật địa chỉ</h3>

        <input id="popup-ten" class="addr-input" placeholder="Họ và tên" />
        <input id="popup-sdt" class="addr-input" placeholder="Số điện thoại" />

        <textarea id="popup-diachi" class="addr-input" placeholder="Địa chỉ cụ thể"></textarea>

        <div style="text-align:right; margin-top:20px;">
            <button id="btn-cancel"
                    style="padding:6px 12px; background:#ccc; border:none; border-radius:3px; cursor:pointer;">
                Trở lại
            </button>

            <button id="btn-save-address"
                    style="padding:6px 12px; background:#ee4d2d; color:white; border:none; border-radius:3px; cursor:pointer;">
                Hoàn thành
            </button>
        </div>
    </div>
</div>

<style>
    .addr-input {
        width: 100%;
        padding: 8px;
        margin-bottom: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
    }
</style>
