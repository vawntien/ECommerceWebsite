@{
    ViewBag.Title = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_LayoutNguoiMua.cshtml";
}

<style>
    body {
        background: #f5f5f5;
        font-family: Arial;
        text-align: center;
    }

    .success-box {
        margin: 150px auto;
        background: #fff;
        padding: 40px;
        width: 600px;
        border-radius: 6px;
        box-shadow: 0 0 8px rgba(0,0,0,0.1);
    }

    h1 {
        color: #28a745;
        margin-bottom: 18px;
    }
</style>

<div class="success-box">
    <h1>Đặt hàng thành công!</h1>
    <p>Cảm ơn bạn đã mua hàng. Đơn hàng của bạn đang chờ xác nhận.</p>

    <a href="/GioHang/Index"
       style="display:inline-block;margin-top:20px;
              background:#ee4d2d;color:#fff;padding:12px 26px;
              text-decoration:none;border-radius:4px;">
        Quay lại giỏ hàng
    </a>
</div>
