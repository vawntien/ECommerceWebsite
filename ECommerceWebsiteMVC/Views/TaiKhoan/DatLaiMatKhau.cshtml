@{
    Layout = null;
}

<div class="register-page-wrapper">
    <!DOCTYPE html>
    <html lang="vi">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Shopee - Đặt Lại Mật Khẩu</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

        <style>
            .register-page-wrapper {
                background: #fff;
                font-family: Arial, sans-serif;
                margin: 0;
                padding: 0;
            }

                .register-page-wrapper .top-header {
                    background: #fff;
                    padding: 12px 0;
                    box-shadow: 0 1px 2px rgba(0,0,0,.05);
                }

                .register-page-wrapper .hero {
                    background: #ee4d2d;
                    padding: 60px 0;
                    min-height: 100vh;
                }

                .register-page-wrapper .hero-left {
                    text-align: center;
                    padding: 40px 20px;
                    color: #fff;
                }

                    .register-page-wrapper .hero-left img {
                        width: 160px;
                    }

                .register-page-wrapper .hero-slogan {
                    text-align: center;
                    color: #fff;
                    font-weight: 150;
                }

                    .register-page-wrapper .hero-slogan .line1, .register-page-wrapper .hero-slogan .line2 {
                        white-space: nowrap;
                        font-size: clamp(26px, 4vw, 30px);
                        line-height: 1.3;
                    }

                .register-page-wrapper .login-box {
                    background: #fff;
                    border-radius: 4px;
                    padding: 30px 40px;
                    width: 100%;
                    max-width: 420px;
                    margin: auto;
                    box-shadow: 0 12px 30px rgba(0,0,0,.16);
                }

                .register-page-wrapper .btn-next {
                    background: #ee4d2d;
                    color: #fff;
                    border: none;
                    height: 45px;
                    font-size: 16px;
                    width: 100%;
                    border-radius: 2px;
                    text-transform: uppercase;
                }

                    .register-page-wrapper .btn-next:hover {
                        background: #c5311d;
                    }

                .register-page-wrapper footer {
                    background: #fafafa;
                    padding: 40px 0;
                    text-align: center;
                    font-size: 12px;
                    color: #777;
                }

                .register-page-wrapper .footer-top a {
                    display: block;
                    text-align: left;
                    color: #555;
                    margin-bottom: 6px;
                    font-size: 13px;
                    text-decoration: none;
                }

                    .register-page-wrapper .footer-top a:hover {
                        color: #ee4d2d;
                    }

                .register-page-wrapper .footer-shopee {
                    background: #fff;
                    border-top: 1px solid #ddd;
                    padding: 20px 0;
                    font-size: 13px;
                    color: #777;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    gap: 30px;
                    white-space: nowrap;
                }

                .register-page-wrapper .footer-locations span {
                    padding: 0 8px;
                    border-right: 1px solid #cfcfcf;
                }

                    .register-page-wrapper .footer-locations span:last-child {
                        border-right: none;
                    }
        </style>
    </head>

    <body class="login-page">
        <header class="top-header">
            <div class="d-flex align-items-center">
                <a href="@Url.Action("Index", "NguoiMua")" style="text-decoration:none; display:flex; align-items:center; ">
                    <img src="~/assets/brand1.png" style="margin-left:15px;" />
                    <span style="font-size: 22px; color: #ee4d2d; font-weight: 700; margin-left: 5px; margin-right: 20px;">Shopee</span>
                </a>
                <span style="font-size:20px;color:black;font-weight:400;">Mật Khẩu Mới</span>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-6 col-md-12 hero-left">
                        <img src="~/assets/shope.png" />
                        <div class="hero-slogan">
                            <div class="line1">Nền tảng thương mại điện tử</div>
                            <div class="line2">yêu thích ở Đông Nam Á & Đài Loan</div>
                        </div>
                    </div>

                    <div class="col-lg-6 col-md-12 d-flex justify-content-center">
                        <div class="login-box">
                            <h4 class="mb-4">Thiết Lập Mật Khẩu</h4>

                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger py-2" style="font-size:14px;">@ViewBag.Error</div>
                            }

                            @using (Html.BeginForm("DatLaiMatKhau", "TaiKhoan", FormMethod.Post))
                            {
                                <div class="mb-3 position-relative">
                                    <input type="password" name="MatKhauMoi" class="form-control" placeholder="Mật khẩu mới" required />
                                </div>
                                <div class="mb-4 position-relative">
                                    <input type="password" name="XacNhanMatKhau" class="form-control" placeholder="Xác nhận mật khẩu" required />
                                </div>

                                <button type="submit" class="btn btn-next">XÁC NHẬN</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="footer-shopee">
            <span>© 2025 Shopee. Tất cả các quyền được bảo lưu.</span>
        </div>
    </body>
</html>
</div>