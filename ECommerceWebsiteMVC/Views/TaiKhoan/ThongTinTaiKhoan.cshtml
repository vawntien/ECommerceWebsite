@model ECommerceWebsiteMVC.Models.NguoiDung
@{
    ViewBag.Title = "Hồ Sơ Tài Khoản";
    Layout = "~/Views/Shared/_LayoutNguoiMua.cshtml";
}

<style>
    /* Reset container của layout để không bị bó hẹp */
    body .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    .profile-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        background: #f5f5f5;
        padding: 150px 0;
        
    }

    .profile-container {
        max-width: 750px;
        width: 100%;
        margin: 0 auto;
        padding: 30px 40px;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
    }

        .profile-container h3 {
            font-size: 22px;
            font-weight: 600;
            color: #333;
        }

        .profile-container p {
            font-size: 14px;
            color: #777;
        }

        .profile-container label {
            font-weight: 500;
            color: #666;
            font-size: 14px;
            margin-bottom: 4px;
        }

    .form-control-plaintext {
        background: #fafafa;
        padding: 10px 14px;
        border-radius: 4px;
        border: 1px solid #eee;
        font-size: 15px;
        color: #444;
    }

    .profile-container input.form-control {
        padding: 10px 14px;
        height: 45px;
        font-size: 15px;
    }

    .profile-container a {
        font-size: 14px;
        color: #007bff;
        text-decoration: none;
    }

        .profile-container a:hover {
            text-decoration: underline;
        }

    .profile-avatar img {
        border: 2px solid #eee;
        transition: 0.2s;
    }

        .profile-avatar img:hover {
            border-color: #ee4d2d;
            transform: scale(1.05);
        }

    .btn-save {
        background: #ee4d2d;
        border: none;
        padding: 10px 35px;
        color: #fff;
        font-size: 15px;
        font-weight: 500;
        border-radius: 4px;
        transition: 0.2s;
    }

        .btn-save:hover {
            background: #d84324;
        }

    .btn-back-home {
        display: inline-block;
        margin-bottom: 15px;
        padding: 6px 14px;
        background: #e3e3e3;
        color: #333 !important;
        border-radius: 4px;
        font-size: 14px;
        text-decoration: none !important;
        transition: background 0.2s, color 0.2s;
    }

        .btn-back-home:hover {
            background: #ffe4db; /* nền cam nhạt */
            color: #ee4d2d !important; /* cam Shopee */
            text-decoration: none !important;
        }

        .btn-back-home:active {
            background: #f5c5b9; /* nền cam đậm hơn */
            color: #c5321d !important; /* cam đậm */
            text-decoration: none !important;
        }


</style>


<div class="profile-wrapper">
    <div class="profile-container">
        <a href="@Url.Action("Index", "NguoiMua")" class="btn-back-home">
            ⬅ Quay lại trang chủ
        </a>

        <h3 class="fw-bold">Hồ Sơ Của Tôi</h3>
        <p class="text-muted">Quản lý thông tin hồ sơ để bảo mật tài khoản</p>

        <form method="post" action="@Url.Action("CapNhatThongTin", "TaiKhoan")">

            <!-- Tên đăng nhập -->
            <div class="mb-3">
                <label class="text-muted">Tên đăng nhập</label>
                <div class="form-control-plaintext">@Model.TaiKhoan</div>
            </div>

            <!-- Họ và tên -->
            <div class="mb-3">
                <label class="text-muted">Họ và tên</label>
                <input type="text" class="form-control" name="HoVaTen" value="@Model.HoVaTen" />
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label class="text-muted">Email</label>
                <div class="form-control-plaintext">
                    @MaskEmail(Model.Email)
                    <a href="#" class="ms-2">Thay Đổi</a>
                </div>
            </div>

            <!-- Số điện thoại -->
            <div class="mb-3">
                <label class="text-muted">Số điện thoại</label>
                <div class="form-control-plaintext">
                    @MaskPhone(Model.SDT)
                    <a href="#" class="ms-2">Thay Đổi</a>
                </div>
            </div>

            <!-- CCCD -->
            <div class="mb-3">
                <label class="text-muted">CCCD</label>
                <div class="form-control-plaintext">@Model.CCCD</div>
            </div>

            <!-- Ngày đăng ký -->
            <div class="mb-3">
                <label class="text-muted">Ngày đăng ký</label>
                <div class="form-control-plaintext">
                    @(Model.NgayDangKy.HasValue ? Model.NgayDangKy.Value.ToString("dd/MM/yyyy") : "")
                </div>
            </div>

            <!-- Ảnh đại diện -->
            <div class="mb-3 profile-avatar">
                <label class="text-muted">Ảnh đại diện</label><br />

                <img src="@Url.Content(string.IsNullOrEmpty(Model.HinhAnh)
                                      ? "~/assets/default-user.png"
                                      : Model.HinhAnh)"
                     width="80" class="rounded-circle" />

                <a class="ms-2" href="#">Thay Ảnh</a>
            </div>
            <center>
                <button type="submit" class="btn-save">Lưu</button>
            </center>
        </form>

    </div>
</div>


@helper MaskEmail(string email)
{
    if (string.IsNullOrEmpty(email))
    {
        @:""
    }
    else
    {
        var p = email.Split('@');
        var masked = p[0].Substring(0, 2) + "********@" + p[1];
        @masked
    }
}

@helper MaskPhone(string phone)
{
    if (string.IsNullOrEmpty(phone))
    {
        @:""
    }
    else
    {
        var masked = new string('*', phone.Length - 2) + phone.Substring(phone.Length - 2);
        @masked
    }
}
