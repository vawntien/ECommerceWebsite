@model ECommerceWebsiteMVC.Models.NguoiMua
@{
    ViewBag.Title = "Hồ Sơ Tài Khoản";
    Layout = "~/Views/Shared/_LayoutNguoiMua.cshtml";
}

<style>
    /* TẤT CẢ CSS CHỈ ÁP DỤNG TRONG TRANG HỒ SƠ */
    .profile-page body .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    .profile-page .profile-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        background: #f5f5f5;
        padding: 150px 0;
    }

    .profile-page .profile-container {
        max-width: 750px;
        width: 100%;
        margin: 0 auto;
        padding: 30px 40px;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
    }

        .profile-page .profile-container h3 {
            font-size: 22px;
            font-weight: 600;
            color: #333;
        }

        .profile-page .profile-container p {
            font-size: 14px;
            color: #777;
        }

        .profile-page .profile-container label {
            font-weight: 500;
            color: #666;
            font-size: 14px;
            margin-bottom: 4px;
        }

    .profile-page .form-control-plaintext {
        background: #fafafa;
        padding: 10px 14px;
        border-radius: 4px;
        border: 1px solid #eee;
        font-size: 15px;
        color: #444;
    }

    .profile-page .profile-container input.form-control {
        padding: 10px 14px;
        height: 45px;
        font-size: 15px;
    }

    .profile-page .profile-container a {
        font-size: 14px;
        color: #007bff;
        text-decoration: none;
    }

        .profile-page .profile-container a:hover {
            text-decoration: underline;
        }

    .profile-page .profile-avatar img {
        border: 2px solid #eee;
        transition: 0.2s;
    }

        .profile-page .profile-avatar img:hover {
            border-color: #ee4d2d;
            transform: scale(1.05);
        }

    .profile-page .btn-save {
        background: #ee4d2d;
        border: none;
        padding: 10px 35px;
        color: #fff;
        font-size: 15px;
        font-weight: 500;
        border-radius: 4px;
        transition: 0.2s;
    }

        .profile-page .btn-save:hover {
            background: #d84324;
        }

    .profile-page .btn-back-home {
        display: inline-block;
        margin-bottom: 15px;
        padding: 6px 14px;
        background: #e3e3e3;
        color: #333 !important;
        border-radius: 4px;
        font-size: 14px;
        text-decoration: none !important;
        transition: background 0.2s, color 0.2s;
    }

        .profile-page .btn-back-home:hover {
            background: #ffe4db;
            color: #ee4d2d !important;
        }

        .profile-page .btn-back-home:active {
            background: #f5c5b9;
            color: #c5321d !important;
        }
</style>
http://localhost:59750/TaiKhoan/DangKy
<div class="profile-page">
    <div class="profile-wrapper">
        <div class="profile-container">

            <a href="@Url.Action("Index", "NguoiMua")" class="btn-back-home">
                ⬅ Quay lại trang chủ
            </a>

            <h3 class="fw-bold">Hồ Sơ Của Tôi</h3>
            <p class="text-muted">Quản lý thông tin hồ sơ để bảo mật tài khoản</p>
            <form method="post" action="@Url.Action("CapNhatThongTin", "TaiKhoan")">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }

                <div class="mb-3">
                    <label class="text-muted">Tên đăng nhập</label>
                    <div class="form-control-plaintext fw-bold">@Model.TaiKhoan</div>
                </div>

                <div class="mb-3">
                    <label class="text-muted">Họ và tên</label>
                    <div class="form-control-plaintext fw-bold">@Model.HoVaTen</div>
                </div>

                <div class="mb-3">
                    <label class="text-muted">Email</label>
                    <div class="input-group">
                        <input type="email" name="Email" class="form-control" value="@Model.Email" placeholder="Nhập email mới" required />
                        <span class="input-group-text bg-white text-success"><i class="fas fa-check"></i></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="text-muted">Số điện thoại</label>
                    <div class="input-group">
                        <input type="text" name="SDT" class="form-control" value="@Model.SDT" placeholder="Nhập SĐT mới" required pattern="[0-9]{10}" title="10 số" />
                        <span class="input-group-text bg-white text-success"><i class="fas fa-check"></i></span>
                    </div>
                </div>

                <center>
                    <button type="submit" class="btn-save">Lưu Thay Đổi</button>
                </center>

            </form>

        </div>
    </div>
</div>

@helper MaskEmail(string email)
{
    if (string.IsNullOrEmpty(email))
    {
        @:""
    }
    else
    {
        var p = email.Split('@');
        var masked = p[0].Substring(0, 2) + "********@" + p[1];
        @masked
    }
}

@helper MaskPhone(string phone)
{
    if (string.IsNullOrEmpty(phone))
    {
        @:""
    }
    else
    {
        var masked = new string('*', phone.Length - 2) + phone.Substring(phone.Length - 2);
        @masked
    }
}
