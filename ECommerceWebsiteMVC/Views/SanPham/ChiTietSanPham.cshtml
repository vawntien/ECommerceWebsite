<body>

        <div class="container py-4">

        <div class="row" style="margin-top:150px">
            <div class="col-md-5">
                <div class="product-gallery">

                    <img id="main-img" style="height: 500px;width: 500px"
                         src="~/Images/Products/@Model.MaSanPham/@Model.AnhSanPhams.First(a => a.MacDinh == true).HinhAnh"
                         class="img-fluid shadow" />

                    <div class="d-flex gap-2 mt-3">
                        @foreach (var img in Model.AnhSanPhams)
                        {
                            <img class="thumb-img" style="height: 60px;width: 60px" src="~/Images/Products/@Model.MaSanPham/@img.HinhAnh"
                                 onclick="document.getElementById('main-img').src=this.src;" />
                        }
                    </div>

                </div>
            </div>

            <div class="col-md-7">
                <h3>@Model.TenSanPham</h3>

                <div class="mt-2">
                    <span class="price-box" id="price">
                        @*@(Model.BienTheSanPhams.FirstOrDefault()?.GiaBan.ToString("N0"))*@
                    </span>
                </div>

                <hr />

                <h5>Chọn loại:</h5>
                <div class="d-flex flex-wrap gap-2 mt-2">
                    @foreach (var bt in Model.BienTheSanPhams)
                    {
                        <button class="variant-btn"
                                data-id="@bt.MaBienThe"
                                data-price="@bt.GiaBan"
                                data-img="@bt.HinhAnh"
                                data-stock="@bt.SoLuongTonKho">
                            @bt.TenBienThe
                        </button>
                    }
                </div>

                <div class="stock mt-1" id="stock">
                    Còn @(Model.BienTheSanPhams.First().SoLuongTonKho) sản phẩm
                </div>


                @*<div class="mt-3">
                    <label>Số lượng:</label>
                    <div class="d-flex align-items-center mt-1">
                        <button class="btn btn-light" onclick="changeQty(-1)">-</button>
                        <input type="text" id="qty" value="1"
                               class="form-control mx-2"
                               style="width:60px; text-align:center" />
                        <button class="btn btn-light" onclick="changeQty(1)">+</button>
                    </div>
                </div>*@

                <hr />

                <div class="mt-3">
                    <button class="btn btn-danger btn-lg me-2">Mua Ngay</button>
                    <button class="btn btn-outline-danger btn-lg">Thêm vào Giỏ</button>
                </div>

            </div>
        </div>
    </div>




    <!-- ================= SCRIPTS ================= -->
    <script>
        const mainImg = document.getElementById("main-img");
        const priceBox = document.getElementById("price");
        const stockBox = document.getElementById("stock");
        const qtyInput = document.getElementById("qty");

// Chọn biến thể
document.querySelectorAll(".variant-btn").forEach(btn => {

    btn.addEventListener("click", function () {

        // Highlight active
        document.querySelectorAll(".variant-btn")
            .forEach(b => b.classList.remove("active"));
        this.classList.add("active");

        // Đổi giá
        priceBox.innerText = Number(this.dataset.price).toLocaleString() + " ₫";

        // Đổi ảnh nếu biến thể có ảnh riêng
        if (this.dataset.img) {
            mainImg.src = "/Images/Products/@Model.MaSanPham/" + this.dataset.img;
        }

        // Đổi tồn kho
        stockBox.innerText = "Còn " + this.dataset.stock + " sản phẩm";
    });

});

// Thay đổi số lượng
function changeQty(val) {
    let qty = parseInt(qtyInput.value) + val;
    if (qty < 1) qty = 1;
    qtyInput.value = qty;
}
    </script>

</body>

