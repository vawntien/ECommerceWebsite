@{
    Layout = null;
    var title = ViewBag.Title ?? "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#ee4d2d",
                        "background-light": "#f5f5f5",
                        "success": "#1CC88A",
                        "info": "#36B9CC",
                        "warning": "#F6C23E"
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>

    @RenderSection("Styles", required: false)
</head>

<body class="bg-background-light font-display text-gray-700">
    <div class="flex h-screen">

        <!-- Sidebar -->
        <div class="hidden lg:flex lg:flex-col lg:w-64 bg-white border-r border-gray-200">
            <div class="flex items-center gap-3 p-4 border-b border-gray-200 h-16">
                <div class="bg-primary text-white rounded-md p-2 flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">data_thresholding</span>
                </div>
                <h1 class="text-gray-800 text-lg font-bold">Admin Panel</h1>
            </div>

            <div class="flex flex-col gap-2 p-4 flex-grow">
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/10 text-primary" href="#">
                    <span class="material-symbols-outlined text-2xl">dashboard</span>
                    <p class="text-sm font-medium">Dashboard</p>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 text-gray-600" href="#">
                    <span class="material-symbols-outlined text-2xl">group</span>
                    <p class="text-sm font-medium">Users</p>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 text-gray-600" href="#">
                    <span class="material-symbols-outlined text-2xl">bar_chart</span>
                    <p class="text-sm font-medium">Reports</p>
                </a>
            </div>
        </div>

        <!-- Main content -->
        <div class="flex flex-col flex-1 overflow-y-auto">

            <!-- Top navbar -->
            <header class="flex items-center justify-between whitespace-nowrap border-b border-gray-200 px-6 py-3 bg-white h-16 sticky top-0 z-10">

                <label class="hidden md:flex flex-col w-full max-w-sm">
                    <div class="flex w-full flex-1 items-stretch rounded-lg h-10">
                        <div class="text-gray-400 flex bg-gray-100 items-center justify-center pl-4 rounded-l-lg">
                            <span class="material-symbols-outlined text-2xl">search</span>
                        </div>
                        <input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg text-gray-800
                        focus:outline-0 focus:ring-primary border-transparent focus:border-transparent bg-gray-100
                        h-full placeholder:text-gray-400 px-4 text-base font-normal leading-normal"
                               placeholder="Search for..." />
                    </div>
                </label>

                <div class="flex flex-1 justify-end items-center gap-4">
                    <div class="flex gap-2">
                        <button class="relative flex items-center justify-center rounded-full h-10 w-10 bg-gray-100
                            text-gray-500 hover:bg-gray-200">
                            <span class="material-symbols-outlined text-xl">notifications</span>

                            <span class="absolute top-2 right-2 flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                            </span>
                        </button>
                    </div>

                    <div class="w-px h-6 bg-gray-200"></div>

                    <div class="flex items-center gap-3">
                        <span class="text-sm font-medium text-gray-700 hidden sm:inline">
                            @User.Identity.Name
                        </span>

                        <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10"
                             style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDyYHIDqieST_0PjgIpSFGdVE4MzLz1TFGJFtprgJcRwYDZqwI1UPyk2p5skARzXGaST6l0s1ZtL01XAN8tHCDhcbhoIE_TNhL3yJjzfcJiRCYZMUPQgqrAUMp3skwfFNQtD-eWRGIB-39soLpqeq3td4EOZTy-dcikZcM5Bxo6JW1EMpnvLknyWpI0nfn2fjyQsApLFzikiEE0qwW6WGs7Y8uP9UB6NurPq9e2-9X6a4qYRuQWPOq1fEbiSy1zL99ttbSX5vwj-Kk");'>
                        </div>
                    </div>
                </div>
            </header>

            <!-- CONTENT: nơi view con nhét vào -->
            <main class="flex-1 p-6">
                @RenderBody()
            </main>

        </div>
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>
