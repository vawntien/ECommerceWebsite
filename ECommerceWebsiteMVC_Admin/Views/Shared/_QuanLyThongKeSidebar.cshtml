@functions {
    public string ActiveSidebar(string controller, string action = "Index")
    {
        var currentController = ViewContext.RouteData.Values["controller"].ToString();
        var currentAction = ViewContext.RouteData.Values["action"].ToString();

        return (currentController == controller && currentAction == action)
            ? "bg-primary/10 text-primary border-l-4 border-primary"
            : "text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10";
    }
}


<aside class="flex w-64 flex-col bg-white dark:bg-background-dark dark:border-r dark:border-white/10 shadow-sm">
    <div class="flex h-16 shrink-0 items-center justify-center border-b dark:border-white/10">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-3xl">store</span>
            <h1 class="text-[#181210] dark:text-white text-xl font-bold">Quản lí thống kê</h1>
        </div>
    </div>

    <div class="flex grow flex-col gap-y-5 overflow-y-auto p-4">
        <nav class="flex flex-1 flex-col">
            <ul class="flex flex-1 flex-col gap-y-4" role="list">
                <li>
                    <div class="flex flex-col gap-2">

                        <a class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold @ActiveSidebar("QuanLyThongKe", "Index")"
                           href="@Url.Action("Index","QuanLyThongKe",null)">
                            <span class="material-symbols-outlined">dashboard</span>
                            <span>Tổng quan</span>
                        </a>

                        <a class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold @ActiveSidebar("QuanLyThongKe", "QuanLyCuaHang")"
                           href="@Url.Action("ThongKeDoanhThuNguoiBan","QuanLyThongKe",null)">
                            <span class="material-symbols-outlined">storefront</span>
                            <span>Thống kê doanh thu người bán</span>
                        </a>


                        <a class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold @ActiveSidebar("QuanLyThongKe", "QuanLyNguoiMua")"
                           href="@Url.Action("ThongKeDoanhThuNganhHang","QuanLyThongKe",null)">
                            <span class="material-symbols-outlined">person</span>
                            <span>Thống kê doanh thu ngành hàng</span>
                        </a>


                        @*<a class="group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold leading-6 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 hover:text-primary" href="#">
                                <span class="material-symbols-outlined">settings</span>
                                <span>Cài đặt</span>
                            </a>*@
                    </div>
                </li>

                <li class="mt-auto">
                    <a class="group -mx-2 flex gap-x-3 rounded-md p-2 text-sm font-semibold leading-6 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-white/10 hover:text-primary" href="#">
                        <span class="material-symbols-outlined">logout</span>
                        Đăng xuất
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</aside>
