@model List<ECommerceWebsiteMVC_Admin.Models.NhanVien>

@{
    ViewBag.Title = "Danh sách Nhân viên";
    Layout = "~/Views/Shared/_QuanLyNhanVienLayout.cshtml";
}

<div class="w-full min-h-screen p-8">

    <main class="w-full bg-white rounded-lg shadow-sm">

        <!-- HEADER -->
        <div class="px-6 py-5 border-b flex justify-between items-center">
            <div>
                <h1 class="text-xl font-medium">Danh sách Nhân viên</h1>
                <p class="text-sm text-gray-500">Quản lý nhân viên và quyền truy cập của họ.</p>
            </div>

            <!-- NÚT CHUYỂN TRANG -->
            <a href="@Url.Action("ThemNhanVien")"
               class="flex items-center gap-2 h-10 px-5 text-sm font-medium text-white bg-primary rounded">
                <span class="material-symbols-outlined text-base">add</span>
                Thêm nhân viên
            </a>
        </div>

        <div class="p-6">

            <!-- TABLE -->
            <div class="overflow-x-auto">
                <table class="w-full min-w-[800px] text-sm text-left">
                    <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
                        <tr>
                            <th class="px-6 py-3 w-16">Avatar</th>
                            <th class="px-6 py-3">Tên nhân viên</th>
                            <th class="px-6 py-3">Email</th>
                            <th class="px-6 py-3 text-center">Quyền</th>
                            <th class="px-6 py-3 text-center">Hành động</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var nv in Model)
                        {
                            <tr class="border-b hover:bg-gray-50">
                                <td class="px-6 py-4">
                                    <div class="rounded-full bg-gray-300 size-10" 
                                          style='background-image: url("https://e7.pngegg.com/pngimages/81/570/png-clipart-profile-logo-computer-icons-user-user-blue-heroes-thumbnail.png");'>
                                         

                                    </div>
                                </td>

                                <td class="px-6 py-4 font-medium">@nv.HoVaTen</td>
                                <td class="px-6 py-4">@nv.Email</td>

                                <td class="px-6 py-4 text-center">
                                    @nv.QuyenHeThong.TenQuyenHeThong
                                </td>

                                <td class="px-6 py-4 text-center text-primary">
                                    <a href="@Url.Action("SuaNhanVien", new { id = nv.MaNhanVien })"
                                       class="hover:underline">Chỉnh sửa | </a>
                                    <a href="@Url.Action("XoaNhanVien", new { id = nv.MaNhanVien })"
                                       class="hover:underline">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>

    </main>
</div>
