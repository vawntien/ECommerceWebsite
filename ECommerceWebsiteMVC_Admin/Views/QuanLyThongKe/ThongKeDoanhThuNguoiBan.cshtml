@model List<ECommerceWebsiteMVC_Admin.Models.ThongKeDoanhThuNguoiBan>

@{
    ViewBag.Title = "Top Người bán Doanh thu cao";
    Layout = "~/Views/Shared/_QuanLyThongKeLayout.cshtml";
}

<div class="p-8">
    <main class="flex-1">

        <!-- HEADER -->
        <div class="flex flex-wrap justify-between items-center gap-4 mb-6">
            <div class="flex flex-col gap-1">
                <h1 class="text-gray-900 text-2xl font-bold">Top Người bán Doanh thu cao</h1>
                <p class="text-gray-500 text-sm">Thống kê theo doanh thu và tổng số đơn hàng.</p>
            </div>
        </div>

        <!-- TABLE -->
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50">
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tên cửa hàng</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Doanh thu</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tổng số đơn</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-200">

                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="px-6 py-4 text-center text-gray-500">
                                Không có dữ liệu.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var it in Model)
                        {
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4 font-medium text-gray-900">@it.TenCuaHang</td>

                                <td class="px-6 py-4 text-gray-700">
                                    @String.Format("{0:N0}₫", it.DoanhThu)
                                </td>

                                <td class="px-6 py-4 text-gray-700">@it.TongSoDon</td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <nav class="flex items-center justify-end mt-4">
            <div class="flex items-center gap-2">

                <!-- Prev -->
                <a href="@Url.Action("ThongKeDoanhThuNguoiBan", new { page = ViewBag.Page - 1 })"
                   class="flex size-8 items-center justify-center text-gray-500 hover:text-primary
                          @(ViewBag.Page == 1 ? "opacity-40 pointer-events-none" : "")">
                    <span class="material-symbols-outlined text-xl">chevron_left</span>
                </a>

                <!-- Page numbers -->
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.Page)
                    {
                        <span class="flex size-8 items-center justify-center bg-primary text-white rounded text-sm">@i</span>
                    }
                    else
                    {
                        <a href="@Url.Action("ThongKeDoanhThuNguoiBan", new { page = i })"
                           class="flex size-8 items-center justify-center rounded text-gray-700 hover:bg-gray-100 text-sm">
                            @i
                        </a>
                    }
                }

                <!-- Next -->
                <a href="@Url.Action("ThongKeDoanhThuNguoiBan", new { page = ViewBag.Page + 1 })"
                   class="flex size-8 items-center justify-center text-gray-500 hover:text-primary
                          @(ViewBag.Page == ViewBag.TotalPages ? "opacity-40 pointer-events-none" : "")">
                    <span class="material-symbols-outlined text-xl">chevron_right</span>
                </a>

            </div>
        </nav>

    </main>
</div>
