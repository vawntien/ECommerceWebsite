@{
    Layout = null;
    ViewBag.Title = "Đăng nhập nhân viên";
}

<!DOCTYPE html>
<html class="light" lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewBag.Title</title>

    <!-- TAILWIND + FONTS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#ee4d2d",
                        "background-light": "#fef5f1",
                        "background-dark": "#23140f",
                    },
                    fontFamily: {
                        display: ["Inter"]
                    }
                }
            }
        }
    </script>

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>

<body class="font-display bg-background-light min-h-screen flex items-center justify-center">

    <!-- FORM LOGIN -->
    <div class="w-full max-w-md bg-white rounded-xl shadow-xl p-8">

        <!-- ICON + TITLE -->
        <div class="text-center mb-6">
            <span class="material-symbols-outlined text-primary mb-4" style="font-size: 48px;">
                storefront
            </span>
            <h1 class="text-[28px] font-bold leading-tight">
                Đăng nhập nhân viên hệ thống
            </h1>
        </div>

        <!-- HIỂN THỊ LỖI NẾU CÓ -->
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
                @ViewBag.Error
            </div>
        }

        <!-- FORM -->
        <form method="post" action="@Url.Action("DangNhap")" class="flex flex-col gap-4">

            <!-- Username -->
            <div>
                <label class="block text-base font-medium mb-1">Email / Tên đăng nhập</label>
                <input name="TaiKhoan"
                       class="w-full h-12 border rounded-lg p-3 focus:ring-primary focus:border-primary"
                       placeholder="Nhập email hoặc tên đăng nhập" />
            </div>

            <!-- Password -->
            <div>
                <label class="block text-base font-medium mb-1">Mật khẩu</label>
                <input name="MatKhau" type="password"
                       class="w-full h-12 border rounded-lg p-3 focus:ring-primary focus:border-primary"
                       placeholder="Nhập mật khẩu" />
            </div>

            <!-- Forgot Password -->
            <!--<div class="flex justify-end">
                <a href="#" class="text-primary text-sm underline">Quên mật khẩu?</a>
            </div>-->

            <!-- SUBMIT BUTTON -->
            <button type="submit"
                    class="h-12 bg-primary text-white rounded-lg font-bold hover:bg-primary/90">
                Đăng nhập
            </button>
        </form>
    </div>

</body>

</html>
