@model ECommerceWebsiteMVC_Admin.Models.GiamGia
@{
    ViewBag.Title = "Sửa khuyến mãi";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
}

<!-- PageHeading -->
<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex flex-col gap-1">
        <h1 class="text-[#181210] dark:text-white text-3xl font-bold leading-tight tracking-tight">Sửa khuyến mãi</h1>
        <p class="text-gray-500 dark:text-gray-400 text-base font-normal leading-normal">Chỉnh sửa thông tin mã giảm giá</p>
    </div>
</div>

<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 max-w-3xl">

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 p-4 bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-300 rounded-lg">
            @ViewBag.Error
        </div>
    }

    <!-- HIỂN THỊ LỖI TỪ ModelState -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-4 p-4 bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-300 rounded-lg">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <form method="post" class="space-y-6">

        <input type="hidden" name="MaGiamGia" value="@Model.MaGiamGia" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Tên mã giảm giá -->
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Tên mã giảm giá <span class="text-red-500">*</span>
                </label>
                <input name="TenMaGG" 
                       value="@Model.TenMaGG"
                       required
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Mô tả -->
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Mô tả
                </label>
                <textarea name="MoTa" 
                          rows="3"
                          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                                 focus:ring-primary focus:border-primary text-sm">@Model.MoTa</textarea>
            </div>

            <!-- Giá trị đơn hàng tối thiểu -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Giá trị đơn hàng tối thiểu (đ) <span class="text-red-500">*</span>
                </label>
                <input type="number" 
                       name="GiaTriDonHangToiThieu" 
                       value="@Model.GiaTriDonHangToiThieu"
                       min="0"
                       step="1000"
                       required
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Giá trị giảm tối đa -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Giá trị giảm tối đa (đ) <span class="text-red-500">*</span>
                </label>
                <input type="number" 
                       name="GiaTriGiamToiDa" 
                       value="@Model.GiaTriGiamToiDa"
                       min="0"
                       step="1000"
                       required
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Giá trị giảm -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Giá trị giảm <span class="text-red-500">*</span>
                </label>
                <div class="space-y-2">
                    <input type="number" 
                           name="GiaTriGiam" 
                           value="@(Model.GiaTriGiam.HasValue ? Model.GiaTriGiam.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")"
                           min="0"
                           step="any"
                           lang="en"
                           inputmode="decimal"
                           required
                           class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                                  focus:ring-primary focus:border-primary text-sm" />
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                        Nhập số từ 0-1 để tính theo phần trăm (VD: 0.1 = 10%), hoặc số lớn hơn 1 để tính theo số tiền cố định (VD: 50000 = 50,000đ)
                    </p>
                </div>
            </div>

            <!-- Ngày bắt đầu -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Ngày bắt đầu
                </label>
                <input type="datetime-local" 
                       name="NgayBD" 
                       value="@(Model.NgayBD.HasValue ? Model.NgayBD.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Ngày kết thúc -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Ngày kết thúc
                </label>
                <input type="datetime-local" 
                       name="NgayKT" 
                       value="@(Model.NgayKT.HasValue ? Model.NgayKT.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

        </div>

        <!-- Buttons -->
        <div class="flex justify-end gap-3 pt-4 border-t dark:border-gray-700">
            <a href="@Url.Action("QuanLyKhuyenMai", "QuanLyNguoiDungHeThong")" 
               class="px-6 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-200 dark:bg-gray-700 rounded-md hover:bg-gray-300 dark:hover:bg-gray-600">
                Hủy
            </a>
            <button type="submit" 
                    class="px-6 py-2 text-sm font-medium text-white bg-primary rounded-md hover:bg-orange-600">
                Lưu
            </button>
        </div>

    </form>

</div>

