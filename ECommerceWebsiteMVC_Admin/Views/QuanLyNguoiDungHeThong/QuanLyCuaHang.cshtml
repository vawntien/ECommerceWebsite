@using ECommerceWebsiteMVC_Admin.Models
@model List<CuaHang>

@{
    ViewBag.Title = "Quản lý Cửa hàng";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
}

<main class="flex-1 p-6">
    <div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6">

        <!-- TÌM KIẾM + BỘ LỌC -->
        <form method="get" action="@Url.Action("QuanLyCuaHang")" class="flex flex-wrap items-center gap-4">

            <!-- Ô tìm kiếm -->
            <div class="relative w-full sm:w-64">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
                    search
                </span>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       placeholder="Tìm theo tên, email"
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                      focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Bộ lọc trạng thái -->
            <div class="relative w-full sm:w-48">
                <select name="status"
                        class="w-full appearance-none border border-gray-300 dark:border-gray-600 rounded-md py-2 px-4 bg-transparent
                       focus:ring-primary focus:border-primary text-sm">

                    <option value="" @(ViewBag.Status == "" ? "selected" : "")>Tất cả trạng thái</option>
                    <option value="active" @(ViewBag.Status == "active" ? "selected" : "")>Đang hoạt động</option>
                    <option value="locked" @(ViewBag.Status == "locked" ? "selected" : "")>Bị khóa</option>
                </select>

                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
                    expand_more
                </span>
            </div>

            <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-orange-600 text-sm">
                Lọc
            </button>
        </form>


        <!-- TABLE -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600 dark:text-slate-300">
                <thead class="text-xs text-slate-500 dark:text-slate-400 uppercase bg-gray-50 dark:bg-gray-800/50">
                    <tr>
                        <th class="px-6 py-3">ID</th>
                        <th class="px-6 py-3">Tên Cửa Hàng</th>
                        <th class="px-6 py-3">Email</th>
                        <th class="px-6 py-3">Số Điện Thoại</th>
                        <th class="px-6 py-3">Trạng Thái</th>
                        <th class="px-6 py-3">Ngày Tham Gia</th>
                        <th class="px-6 py-3 text-center">Hành Động</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var it in Model)
                    {
                        <tr class="bg-white dark:bg-[#2c1d17] border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800">

                            <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">@it.MaCuaHang</td>
                            <td class="px-6 py-4">@it.TenCuaHang</td>
                            <td class="px-6 py-4">@it.NguoiBan.Email</td>
                            <td class="px-6 py-4">@it.NguoiBan.SDT</td>

                            <td class="px-6 py-4">
                                @if (it.TrangThai)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs
                                                 font-medium bg-green-100 text-green-800
                                                 dark:bg-green-900 dark:text-green-300">
                                        Đang hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs
                                                 font-medium bg-red-100 text-red-800
                                                 dark:bg-red-900 dark:text-red-300">
                                        Bị khóa
                                    </span>
                                }
                            </td>

                            <td class="px-6 py-4">
                                @(it.NgayDangKy.HasValue ? it.NgayDangKy.Value.ToString("dd/MM/yyyy") : "")
                            </td>

                            <td class="px-6 py-4 flex items-center justify-center gap-2">
                                <button class="px-3 py-1 text-xs font-medium text-slate-700 dark:text-slate-300
                                               bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600
                                               rounded-md hover:bg-gray-100 dark:hover:bg-gray-600">
                                    @Html.ActionLink("Xem chi tiết", "ChiTietCuaHang", new { @pMaCH = it.MaCuaHang })
                                </button>

                                @if (it.TrangThai)
                                {
                                    <button class="px-3 py-1 text-xs font-medium text-white bg-red-500 rounded-md hover:bg-red-600">
                                        @Html.ActionLink("Khóa", "ThayDoiTrangThaiCuaHang", "QuanLyNguoiDungHeThong", new {@pMaCH = it.MaCuaHang, @pURL = Request.Url},null)
                                    </button>
                                }
                                else
                                {
                            <button class="px-3 py-1 text-xs font-medium text-white bg-primary rounded-md hover:bg-orange-600">
                                
                                @Html.ActionLink("Mở khóa", "ThayDoiTrangThaiCuaHang", "QuanLyNguoiDungHeThong", new { @pMaCH = it.MaCuaHang, @pURL = Request.Url }, null)

                            </button>
                                }
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PHÂN TRANG -->
        <nav class="flex flex-col sm:flex-row items-center justify-between pt-5 gap-4">

            <!-- Hiển thị "1 - 10 trên 100" -->
            <div class="text-sm text-slate-500 dark:text-slate-400">
                <span class="font-semibold text-slate-900 dark:text-white">@ViewBag.From</span> -
                <span class="font-semibold text-slate-900 dark:text-white">@ViewBag.To</span>
                trên
                <span class="font-semibold text-slate-900 dark:text-white">@ViewBag.TotalItems</span>
            </div>

            <!-- Nút phân trang -->
            <div class="flex items-center gap-2">

                <!-- Prev -->
                <a href="@Url.Action("QuanLyCuaHang", new { page = ViewBag.Page - 1 })"
                   class="@(ViewBag.Page == 1 ? "pointer-events-none opacity-50" : "")
                          flex items-center justify-center h-8 w-8 rounded-md bg-white dark:bg-gray-700
                          border border-gray-300 dark:border-gray-600 text-slate-500 dark:text-slate-400
                          hover:bg-gray-100 dark:hover:bg-gray-800">
                    <span class="material-symbols-outlined text-lg">chevron_left</span>
                </a>

                <!-- Page numbers -->
                <div class="flex items-center gap-2">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        if (i == ViewBag.Page)
                        {
                            <button class="flex items-center justify-center h-8 w-8 rounded-md bg-primary text-white text-sm">
                                @i
                            </button>
                        }
                        else
                        {
                            <a href="@Url.Action("QuanLyCuaHang", new { page = i })"
                               class="flex items-center justify-center h-8 w-8 rounded-md bg-white dark:bg-gray-700
                                      border border-gray-300 dark:border-gray-600 text-slate-500 dark:text-slate-400
                                      hover:bg-gray-100 dark:hover:bg-gray-800 text-sm">
                                @i
                            </a>
                        }
                    }
                </div>

                <!-- Next -->
                <a href="@Url.Action("QuanLyCuaHang", new { page = ViewBag.Page + 1 })"
                   class="@(ViewBag.Page == ViewBag.TotalPages ? "pointer-events-none opacity-50" : "")
                          flex items-center justify-center h-8 w-8 rounded-md bg-white dark:bg-gray-700
                          border border-gray-300 dark:border-gray-600 text-slate-500 dark:text-slate-400
                          hover:bg-gray-100 dark:hover:bg-gray-800">
                    <span class="material-symbols-outlined text-lg">chevron_right</span>
                </a>

            </div>

        </nav>

    </div>
</main>
