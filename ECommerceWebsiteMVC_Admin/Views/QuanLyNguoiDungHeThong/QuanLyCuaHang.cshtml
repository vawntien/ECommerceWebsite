@using ECommerceWebsiteMVC_Admin.Models
@model List<CuaHang>

@{
    ViewBag.Title = "Quản lý Cửa hàng";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
}

<main class="flex-1 p-6">
    <div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6">

        <!-- ================= THÔNG BÁO ================= -->
        @if (TempData["Success"] != null)
        {
            <div class="mb-5 flex items-center rounded-lg bg-green-100 px-4 py-3 text-green-800">
                <span class="material-symbols-outlined mr-2">check_circle</span>
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-5 flex items-center rounded-lg bg-red-100 px-4 py-3 text-red-800">
                <span class="material-symbols-outlined mr-2">error</span>
                @TempData["Error"]
            </div>
        }

        <!-- ================= TÌM KIẾM + BỘ LỌC ================= -->
        <form method="get"
              action="@Url.Action("QuanLyCuaHang")"
              class="flex flex-wrap items-center gap-4 mb-6">

            <div class="relative w-full sm:w-64">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">
                    search
                </span>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       placeholder="Tìm theo tên, email"
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <div class="relative w-full sm:w-48">
                <select name="status"
                        class="w-full appearance-none border border-gray-300 dark:border-gray-600 rounded-md
                               py-2 px-4 bg-transparent focus:ring-primary focus:border-primary text-sm">
                    <option value="">Tất cả trạng thái</option>
                    <option value="active" @(ViewBag.Status == "active" ? "selected" : "")>Đang hoạt động</option>
                    <option value="locked" @(ViewBag.Status == "locked" ? "selected" : "")>Bị khóa</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">
                    expand_more
                </span>
            </div>

            <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-orange-600 text-sm">
                Lọc
            </button>
        </form>

        <!-- ================= TABLE ================= -->
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-slate-600 dark:text-slate-300">
                <thead class="text-xs uppercase bg-gray-50 dark:bg-gray-800/50">
                    <tr>
                        <th class="px-6 py-3">ID</th>
                        <th class="px-6 py-3">Tên cửa hàng</th>
                        <th class="px-6 py-3">Email</th>
                        <th class="px-6 py-3">SĐT</th>
                        <th class="px-6 py-3">Trạng thái</th>
                        <th class="px-6 py-3">Ngày tham gia</th>
                        <th class="px-6 py-3 text-center">Hành động</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var it in Model)
                        {
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800">

                                <td class="px-6 py-4 font-medium text-slate-900 dark:text-white">
                                    @it.MaCuaHang
                                </td>

                                <td class="px-6 py-4">@it.TenCuaHang</td>
                                <td class="px-6 py-4">@it.NguoiBan.Email</td>
                                <td class="px-6 py-4">@it.NguoiBan.SDT</td>

                                <td class="px-6 py-4">
                                    @if (it.TrangThai)
                                    {
                                        <span class="px-2 py-1 rounded-full text-xs bg-green-100 text-green-800">
                                            Đang hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 rounded-full text-xs bg-red-100 text-red-800">
                                            Bị khóa
                                        </span>
                                    }
                                </td>

                                <td class="px-6 py-4">
                                    @(it.NgayDangKy.HasValue ? it.NgayDangKy.Value.ToString("dd/MM/yyyy") : "")
                                </td>

                                <!-- HÀNH ĐỘNG -->
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2">

                                        <a href="@Url.Action("ChiTietCuaHang", new { pMaCH = it.MaCuaHang })"
                                           class="px-3 py-1 text-xs rounded-md border
                                                  bg-white dark:bg-gray-700
                                                  hover:bg-gray-100 dark:hover:bg-gray-600">
                                            Xem chi tiết
                                        </a>

                                        <button type="button"
                                                onclick="openConfirmModal(@it.MaCuaHang, @(it.TrangThai ? "true" : "false"))"
                                                class="px-3 py-1 text-xs rounded-md text-white
                                                       @(it.TrangThai
                                                         ? "bg-red-500 hover:bg-red-600"
                                                         : "bg-primary hover:bg-orange-600")">
                                            @(it.TrangThai ? "Khóa" : "Mở khóa")
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-6 text-center text-slate-500">
                                Không có cửa hàng nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- ================= PHÂN TRANG ================= -->
        <div class="flex items-center justify-between pt-5 text-sm">

            <div>
                <span class="font-semibold">@ViewBag.From</span> -
                <span class="font-semibold">@ViewBag.To</span> /
                <span class="font-semibold">@ViewBag.TotalItems</span>
            </div>

            <div class="flex gap-2">
                <a href="@Url.Action("QuanLyCuaHang", new { page = ViewBag.Page - 1 })"
                   class="@(ViewBag.Page == 1 ? "pointer-events-none opacity-50" : "") px-3 py-1 border rounded">
                    ‹
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.Page)
                    {
                        <span class="px-3 py-1 bg-primary text-white rounded">@i</span>
                    }
                    else
                    {
                        <a href="@Url.Action("QuanLyCuaHang", new { page = i })"
                           class="px-3 py-1 border rounded">@i</a>
                    }
                }

                <a href="@Url.Action("QuanLyCuaHang", new { page = ViewBag.Page + 1 })"
                   class="@(ViewBag.Page == ViewBag.TotalPages ? "pointer-events-none opacity-50" : "") px-3 py-1 border rounded">
                    ›
                </a>
            </div>
        </div>
    </div>
</main>

<!-- ================= MODAL XÁC NHẬN ================= -->
<div id="confirmModal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">

    <div class="bg-white dark:bg-[#2c1d17] rounded-lg w-full max-w-md p-6">
        <h3 class="text-lg font-semibold mb-2">Xác nhận thao tác</h3>

        <p id="confirmMessage" class="text-sm mb-6"></p>

        <div class="flex justify-end gap-3">
            <button onclick="closeConfirmModal()"
                    class="px-4 py-2 border rounded">
                Hủy
            </button>

            <a id="confirmActionBtn"
               class="px-4 py-2 bg-primary text-white rounded">
                Xác nhận
            </a>
        </div>
    </div>
</div>

<script>
    function openConfirmModal(maCH, isActive) {
        const modal = document.getElementById("confirmModal");
        const msg = document.getElementById("confirmMessage");
        const btn = document.getElementById("confirmActionBtn");

        msg.innerText = isActive
            ? "Bạn có chắc chắn muốn KHÓA cửa hàng này?"
            : "Bạn có chắc chắn muốn MỞ KHÓA cửa hàng này?";

        btn.href = `/QuanLyNguoiDungHeThong/ThayDoiTrangThaiCuaHang?pMaCH=${maCH}&pURL=${encodeURIComponent(window.location.href)}`;

        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closeConfirmModal() {
        const modal = document.getElementById("confirmModal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
    }
</script>
