@using ECommerceWebsiteMVC_Admin.Models
@model List<NguoiMua>

@{
    ViewBag.Title = "Quản lý Người Mua";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";

    string keyword = ViewBag.Keyword ?? "";
    string filterType = ViewBag.FilterType ?? "email";
}

<main class="flex flex-1 flex-col p-6">
    <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">
        Quản lý Người Mua
    </h1>

    <div class="bg-white dark:bg-background-dark p-6 rounded-lg shadow-sm">

        <!--  THANH TÌM KIẾM -->
        <form method="get" action="@Url.Action("QuanLyNguoiMua")"
              class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-4">

            <div class="flex items-center gap-4 w-full sm:w-auto">

                <div class="relative w-full max-w-xs">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-neutral-500">search</span>
                    </div>
                    <input name="keyword"
                           value="@keyword"
                           placeholder="Tìm kiếm..."
                           class="form-input w-full pl-10 pr-4 py-2 border border-neutral-300
                                  dark:border-neutral-700 rounded-lg bg-white dark:bg-neutral-800
                                  text-neutral-900 dark:text-neutral-100" />
                </div>

                <select name="filterType"
                        class="form-select border-neutral-300 dark:border-neutral-700 rounded-lg
                               bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100">
                    <option value="email" @(filterType == "email" ? "selected" : "")>Email</option>
                    <option value="phone" @(filterType == "phone" ? "selected" : "")>Số điện thoại</option>
                </select>

            </div>

            <div class="flex gap-2">
                <a href="@Url.Action("QuanLyNguoiMua")"
                   class="flex h-10 px-4 items-center justify-center rounded-lg
                          border border-neutral-300 dark:border-neutral-700">
                    Đặt lại
                </a>

                <button type="submit"
                        class="flex h-10 px-4 items-center justify-center rounded-lg
                               bg-primary text-white">
                    Tìm kiếm
                </button>
            </div>
        </form>

        <!--  TABLE -->
        <div class="overflow-x-auto">
            <table class="w-full min-w-[900px] text-sm text-left border border-neutral-200 dark:border-neutral-700">

                <thead class="bg-neutral-50 dark:bg-white/5">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="px-4 py-3">Tên Người Mua</th>
                        <th class="px-4 py-3">Email</th>
                        <th class="px-4 py-3">SĐT</th>
                        <th class="px-4 py-3 text-center">Trạng thái</th>
                        <th class="px-4 py-3 text-center">Hành động</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-neutral-200 dark:divide-neutral-700">

                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-neutral-50 dark:hover:bg-white/5">

                            <td class="px-4 py-3">@item.MaNguoiMua</td>

                            <td class="px-4 py-3 font-medium">
                                @item.HoVaTen
                            </td>

                            <td class="px-4 py-3">@item.Email</td>

                            <td class="px-4 py-3">@item.SDT</td>

                            <!-- TRẠNG THÁI -->
                            <td class="px-4 py-3 text-center">
                                @if (item.TrangThai)
                                {
                                    <span class="px-2 py-1 rounded-full text-xs bg-green-100 text-green-700">
                                        Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 rounded-full text-xs bg-red-100 text-red-700">
                                        Bị khóa
                                    </span>
                                }
                            </td>

                            <!-- HÀNH ĐỘNG -->
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-center gap-3">

                                    <a href="@Url.Action("ChiTietNguoiMua", new { pMaNM = item.MaNguoiMua })"
                                       class="text-primary text-sm hover:underline">
                                        Chi tiết
                                    </a>

                                    <a href="@Url.Action("ThayDoiTrangThaiNguoiMua",
                                             new {
                                                 pMaNM = item.MaNguoiMua,
                                                 returnUrl = Request.RawUrl
                                             })"
                                       class="text-sm font-medium
                                              @(item.TrangThai ? "text-red-600" : "text-green-600")"
                                       onclick="return confirm('Bạn có chắc muốn thay đổi trạng thái người mua này?');">
                                        @(item.TrangThai ? "Khóa" : "Mở")
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

        <!--PHÂN TRANG  -->
        <div class="flex justify-end mt-6">
            <div class="flex items-center gap-2">

                <a href="@Url.Action("QuanLyNguoiMua", new { page = ViewBag.Page - 1, keyword, filterType })"
                   class="px-3 py-1 border rounded
                          @(ViewBag.Page == 1 ? "opacity-50 pointer-events-none" : "")">
                    ‹
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.Page)
                    {
                        <span class="px-3 py-1 bg-primary text-white rounded">@i</span>
                    }
                    else
                    {
                        <a href="@Url.Action("QuanLyNguoiMua", new { page = i, keyword, filterType })"
                           class="px-3 py-1 border rounded">@i</a>
                    }
                }

                <a href="@Url.Action("QuanLyNguoiMua", new { page = ViewBag.Page + 1, keyword, filterType })"
                   class="px-3 py-1 border rounded
                          @(ViewBag.Page == ViewBag.TotalPages ? "opacity-50 pointer-events-none" : "")">
                    ›
                </a>

            </div>
        </div>

    </div>
</main>
