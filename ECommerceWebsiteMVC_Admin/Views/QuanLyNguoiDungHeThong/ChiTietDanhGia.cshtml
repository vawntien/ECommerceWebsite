@using ECommerceWebsiteMVC_Admin.Models
@model DanhGiaSanPham

@{
    Layout = null;
    var macdinh = Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.AnhSanPhams
        .Where(x => x.MacDinh == true)
        .Select(x => x.HinhAnh)
        .FirstOrDefault()
        ?? Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.AnhSanPhams
            .Select(x => x.HinhAnh)
            .FirstOrDefault();

    var productImageUrl = !string.IsNullOrEmpty(macdinh)
        ? $"https://ecommerceshopstorage.blob.core.windows.net/products/{Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.MaSanPham}/{macdinh}"
        : "https://via.placeholder.com/80?text=No+Image";

    var hasReviewImage = !string.IsNullOrEmpty(Model.HinhAnh);
    var reviewImageUrl = hasReviewImage
        ? $"https://ecommerceshopstorage.blob.core.windows.net/reviews/{Model.HinhAnh}"
        : "";
}

<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />

<style>
    .modal-content-card {
        background: white;
        border-radius: 0.5rem;
        padding: 1.5rem;
        box-shadow: 0 10px 15px rgba(0,0,0,0.08);
        position: relative;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end; /* chỉ còn nút bên phải */
        margin-top: 1rem;
    }

    .star-icon {
        font-size: 1.5rem;
        color: #fbbf24;
    }

        .star-icon.empty {
            color: #d1d5db;
        }

    /* NÚT XÓA ĐÁNH GIÁ – STYLE MỚI */
    .btn-delete-review {
        padding: 0.5rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #fff;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        background: linear-gradient(135deg, #ff512f, #dd2476);
        box-shadow: 0 6px 14px rgba(255, 80, 80, 0.35);
        transition: all 0.2s ease;
    }

        .btn-delete-review:hover {
            background: linear-gradient(135deg, #e63e2b, #c81d65);
            box-shadow: 0 8px 18px rgba(255, 80, 80, 0.45);
            transform: translateY(-1px);
        }

        .btn-delete-review:active {
            transform: scale(0.97);
        }
</style>

<div class="w-full max-w-2xl mx-auto p-4">
    <div class="modal-content-card">

        <!-- Product Info -->
        <div class="bg-gray-50 rounded-lg border border-gray-100 overflow-hidden mb-3 p-3">
            <div class="flex items-start gap-3">
                <div class="w-16 h-16 rounded-md bg-gray-100 overflow-hidden border flex-shrink-0">
                    <img src="@productImageUrl" class="w-full h-full object-cover" />
                </div>
                <div class="flex-1">
                    <h3 class="font-medium text-gray-900 text-sm">
                        @Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.SanPham.TenSanPham
                    </h3>
                    <p class="text-xs text-gray-500 mt-1">
                        SKU: @Model.ChiTietDonHang.ChiTietGioHang.BienTheSanPham.MaBienThe
                    </p>
                </div>
            </div>
        </div>

        <!-- Reviewer Info -->
        <div class="bg-gray-50 rounded-lg border border-gray-100 p-3 mb-3">
            <div class="flex items-center gap-2">
                <span class="material-icons text-gray-400">account_circle</span>
                <div>
                    <p class="font-medium text-gray-900 text-sm">
                        @Model.ChiTietDonHang.ChiTietGioHang.GioHang.NguoiMua.TaiKhoan
                    </p>
                    <p class="text-xs text-gray-500">
                        @(Model.ThoiGian.HasValue
                            ? Model.ThoiGian.Value.ToString("dd/MM/yyyy HH:mm")
                            : "—")
                    </p>
                </div>
            </div>
        </div>

        <!-- Rating -->
        <div class="bg-gray-50 rounded-lg border border-gray-100 p-3 mb-3">
            <div class="flex items-center gap-1 mb-2">
                @{
                    string[] ratingLabels = { "", "Tệ", "Tạm ổn", "Khá", "Tốt", "Tuyệt vời" };
                    string label = (Model.SoSao >= 1 && Model.SoSao <= 5)
                        ? ratingLabels[Model.SoSao]
                        : "";
                }
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="material-icons @(i <= Model.SoSao ? "star-icon" : "star-icon empty")">star</span>
                }
                <span class="text-amber-600 font-semibold text-sm ml-1">@label</span>
            </div>

            <h4 class="font-bold text-gray-900 text-sm mb-1">@Model.TieuDe</h4>
            <p class="text-gray-700 text-sm">@Model.NoiDung</p>

            @if (hasReviewImage)
            {
                <div class="mt-3">
                    <img src="@reviewImageUrl" class="w-20 h-20 object-cover rounded border" />
                </div>
            }
        </div>
    </div>

    <!-- FOOTER -->
    <div class="modal-footer">
        <button id="btnDeleteReview" class="btn-delete-review" data-madg="@Model.MaDG">
            XÓA ĐÁNH GIÁ
        </button>
    </div>
</div>

