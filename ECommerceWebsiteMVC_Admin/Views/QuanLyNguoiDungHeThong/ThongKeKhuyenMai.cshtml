@using ECommerceWebsiteMVC_Admin.Models
@using System
@model ThongKeKhuyenMai

@{
    ViewBag.Title = "Thống kê Khuyến mãi";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
}

<!-- PageHeading -->
<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex flex-col gap-1">
        <h1 class="text-[#181210] dark:text-white text-3xl font-bold leading-tight tracking-tight">Thống kê Khuyến mãi</h1>
        <p class="text-gray-500 dark:text-gray-400 text-base font-normal leading-normal">Thống kê doanh thu và hiệu quả của các chương trình khuyến mãi</p>
    </div>
    <div class="flex gap-2">
        <a href="@Url.Action("QuanLyKhuyenMai", "QuanLyNguoiDungHeThong")"
           class="flex max-w-[480px] cursor-pointer items-center justify-center gap-2 overflow-hidden rounded-lg h-10 min-w-0 px-4 text-sm font-semibold leading-normal bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            <span>Quay lại</span>
        </a>
    </div>
</div>

<!-- Bộ lọc -->
<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-lg font-semibold mb-4 text-gray-800 dark:text-white">Lọc dữ liệu</h2>
    <form method="get" action="@Url.Action("ThongKeKhuyenMai", "QuanLyNguoiDungHeThong")" class="flex flex-wrap items-end gap-4">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Từ ngày</label>
            <input type="date" 
                   name="tuNgay" 
                   value="@ViewBag.TuNgay"
                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                          focus:ring-primary focus:border-primary text-sm" />
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Đến ngày</label>
            <input type="date" 
                   name="denNgay" 
                   value="@ViewBag.DenNgay"
                   class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                          focus:ring-primary focus:border-primary text-sm" />
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Mã giảm giá</label>
            <select name="maVoucher" 
                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                           focus:ring-primary focus:border-primary text-sm">
                <option value="">Tất cả</option>
                @if (Model.DanhSachVoucher != null)
                {
                    foreach (var voucher in Model.DanhSachVoucher)
                    {
                        var isSelected = ViewBag.MaVoucher != null && (int)ViewBag.MaVoucher == voucher.MaGiamGia;
                        var displayName = voucher.TenMaGG;
                        if (displayName != null && displayName.StartsWith("[CAMPAIGN]"))
                        {
                            displayName = displayName.Replace("[CAMPAIGN]", "").Trim();
                        }
                        <option value="@voucher.MaGiamGia" @(isSelected ? "selected" : "")>@displayName</option>
                    }
                }
            </select>
        </div>
        <div>
            <button type="submit"
                    class="px-6 py-2 bg-primary text-white rounded-md hover:bg-orange-600 font-medium text-sm">
                Lọc
            </button>
        </div>
        <div>
            <a href="@Url.Action("ThongKeKhuyenMai", "QuanLyNguoiDungHeThong")"
               class="px-6 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-md hover:bg-gray-200 dark:hover:bg-gray-600 font-medium text-sm">
                Xóa bộ lọc
            </a>
        </div>
    </form>
</div>

<!-- PHẦN 1: TỔNG QUAN DOANH THU -->
<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">Tổng quan Doanh thu từ Khuyến mãi</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Tổng số tiền đã giảm -->
        <div class="bg-gradient-to-br from-red-50 to-red-100 dark:from-red-900/20 dark:to-red-800/20 rounded-lg p-6 border border-red-200 dark:border-red-800">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-red-700 dark:text-red-300">Tổng tiền đã giảm</span>
                <span class="material-symbols-outlined text-red-600 dark:text-red-400">savings</span>
            </div>
            <p class="text-2xl font-bold text-red-800 dark:text-red-200">
                @Model.TongTienGiamChoKhachHang.ToString("N0") đ
            </p>
            <p class="text-xs text-red-600 dark:text-red-400 mt-1">Số tiền đã giảm cho khách hàng</p>
        </div>

        <!-- Thông tin giảm giá -->
        <div class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900/20 dark:to-orange-800/20 rounded-lg p-6 border border-orange-200 dark:border-orange-800">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-orange-700 dark:text-orange-300">Giảm giá</span>
                <span class="material-symbols-outlined text-orange-600 dark:text-orange-400">local_offer</span>
            </div>
            <p class="text-2xl font-bold text-orange-800 dark:text-orange-200">
                @{
                    var voucherSelected = ViewBag.VoucherSelected as GiamGia;
                    if (voucherSelected != null && voucherSelected.GiaTriGiam.HasValue)
                    {
                        double giaTriGiam = voucherSelected.GiaTriGiam.Value;
                        
                        // Kiểm tra nếu là Campaign (có prefix [CAMPAIGN])
                        bool isCampaign = voucherSelected.TenMaGG != null && voucherSelected.TenMaGG.StartsWith("[CAMPAIGN]");
                        
                        if (isCampaign && !string.IsNullOrEmpty(voucherSelected.MoTa))
                        {
                            // Campaign: Parse từ MoTa
                            try
                            {
                                var parts = voucherSelected.MoTa.Split(new[] { "|||" }, StringSplitOptions.None);
                                if (parts.Length > 0)
                                {
                                    string loaiGiamGia = parts[0];
                                    if (loaiGiamGia == "PhanTram")
                                    {
                                        // Giảm theo phần trăm
                                        double phanTram = giaTriGiam;
                                        <text>Giảm @phanTram.ToString("N0")%</text>
                                    }
                                    else
                                    {
                                        // Giảm theo số tiền
                                        <text>Giảm @(((decimal)giaTriGiam).ToString("N0")) đ</text>
                                    }
                                }
                                else
                                {
                                    <text>--</text>
                                }
                            }
                            catch
                            {
                                <text>--</text>
                            }
                        }
                        else
                        {
                            // Voucher thông thường
                            if (giaTriGiam > 0 && giaTriGiam <= 1)
                            {
                                // Giảm theo phần trăm (0.1 = 10%, 0.2 = 20%, etc.)
                                double phanTram = giaTriGiam * 100;
                                <text>Giảm @phanTram.ToString("N0")%</text>
                            }
                            else if (giaTriGiam > 1)
                            {
                                // Giảm theo số tiền (ví dụ: 50000 = 50.000 đ)
                                <text>Giảm @(((decimal)giaTriGiam).ToString("N0")) đ</text>
                            }
                            else
                            {
                                <text>--</text>
                            }
                        }
                    }
                    else
                    {
                        <text>--</text>
                    }
                }
            </p>
            <p class="text-xs text-orange-600 dark:text-orange-400 mt-1">
                @if (voucherSelected != null)
                {
                    <text>Mã giảm giá đã chọn</text>
                }
                else
                {
                    <text>Chưa chọn mã giảm giá</text>
                }
            </p>
        </div>

        <!-- Tổng doanh thu từ voucher -->
        <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-lg p-6 border border-green-200 dark:border-green-800">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-green-700 dark:text-green-300">Tổng doanh thu</span>
                <span class="material-symbols-outlined text-green-600 dark:text-green-400">payments</span>
            </div>
            <p class="text-2xl font-bold text-green-800 dark:text-green-200">
                @Model.TongDoanhThuTuVoucher.ToString("N0") đ
            </p>
            <p class="text-xs text-green-600 dark:text-green-400 mt-1">Doanh thu từ đơn hàng có voucher</p>
        </div>

        <!-- Tổng số đơn hàng -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 rounded-lg p-6 border border-blue-200 dark:border-blue-800">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-blue-700 dark:text-blue-300">Số đơn hàng</span>
                <span class="material-symbols-outlined text-blue-600 dark:text-blue-400">receipt_long</span>
            </div>
            <p class="text-2xl font-bold text-blue-800 dark:text-blue-200">
                @Model.TongSoDonHangSuDungVoucher
            </p>
            <p class="text-xs text-blue-600 dark:text-blue-400 mt-1">Đơn hàng đã sử dụng voucher</p>
        </div>
    </div>
</div>

<!-- BIỂU ĐỒ -->
<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">So sánh Voucher</h2>
    <canvas id="soSanhChart" style="max-height: 300px;"></canvas>
</div>

<!-- PHẦN 2: XẾP HẠNG VOUCHER HIỆU QUẢ -->
<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">Xếp hạng Voucher hiệu quả</h2>
    
    @if (Model.XepHangVoucher != null && Model.XepHangVoucher.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">STT</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Tên Voucher</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Số lần sử dụng</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Tổng tiền giảm</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Tổng doanh thu</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Thời gian</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int stt = 1; }
                    @foreach (var voucher in Model.XepHangVoucher)
                    {
                        <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                            <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">@stt</td>
                            <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                                <a href="@Url.Action("ChiTietKhuyenMai", "QuanLyNguoiDungHeThong", new { id = voucher.MaGiamGia })"
                                   class="text-primary hover:underline">
                                    @voucher.TenMaGG
                                </a>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                                    @voucher.SoLanSuDung lần
                                </span>
                            </td>
                            <td class="px-4 py-3 text-sm text-red-600 dark:text-red-400 font-medium">
                                @voucher.TongTienGiam.ToString("N0") đ
                            </td>
                            <td class="px-4 py-3 text-sm text-green-600 dark:text-green-400 font-medium">
                                @voucher.TongDoanhThu.ToString("N0") đ
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
                                @if (voucher.NgayBD.HasValue && voucher.NgayKT.HasValue)
                                {
                                    <span>@voucher.NgayBD.Value.ToString("dd/MM/yyyy") - @voucher.NgayKT.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else if (voucher.NgayBD.HasValue)
                                {
                                    <span>Từ @voucher.NgayBD.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else if (voucher.NgayKT.HasValue)
                                {
                                    <span>Đến @voucher.NgayKT.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span>Không giới hạn</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @if (voucher.TrangThai == "Đang hiệu lực")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                        @voucher.TrangThai
                                    </span>
                                }
                                else if (voucher.TrangThai == "Hết hạn")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                                        @voucher.TrangThai
                                    </span>
                                }
                                else if (voucher.TrangThai == "Sắp diễn ra")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                                        @voucher.TrangThai
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200">
                                        @voucher.TrangThai
                                    </span>
                                }
                            </td>
                        </tr>
                        stt++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-12 text-gray-500 dark:text-gray-400">
            <span class="material-symbols-outlined text-6xl mb-4 opacity-50">bar_chart</span>
            <p>Chưa có dữ liệu thống kê voucher</p>
        </div>
    }
</div>

<!-- PHẦN 3: LỊCH SỬ SỬ DỤNG VOUCHER -->
<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6">
    <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-white">Lịch sử sử dụng Voucher</h2>
    
    @if (Model.LichSuSuDung != null && Model.LichSuSuDung.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Mã đơn hàng</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Khách hàng</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Email</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Voucher</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Số tiền giảm</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Tổng tiền đơn hàng</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Thời gian</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lichSu in Model.LichSuSuDung)
                    {
                        <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50">
                            <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                                #@lichSu.MaDonHang
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">
                                @lichSu.TenKhachHang
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
                                @lichSu.Email
                            </td>
                            <td class="px-4 py-3 text-sm text-primary font-medium">
                                @lichSu.TenVoucher
                            </td>
                            <td class="px-4 py-3 text-sm text-red-600 dark:text-red-400 font-medium">
                                @lichSu.SoTienGiam.ToString("N0") đ
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 font-medium">
                                @lichSu.TongTienDonHang.ToString("N0") đ
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">
                                @lichSu.ThoiGianDat.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @if (lichSu.TrangThaiDonHang == "Đã hoàn thành")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                        @lichSu.TrangThaiDonHang
                                    </span>
                                }
                                else if (lichSu.TrangThaiDonHang == "Đã hủy")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                                        @lichSu.TrangThaiDonHang
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                                        @lichSu.TrangThaiDonHang
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-12 text-gray-500 dark:text-gray-400">
            <span class="material-symbols-outlined text-6xl mb-4 opacity-50">history</span>
            <p>Chưa có lịch sử sử dụng voucher</p>
        </div>
    }
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    var duLieuVoucher = @Html.Raw(ViewBag.DuLieuVoucherJson);

    if (duLieuVoucher && duLieuVoucher.length > 0) {
        var labelsVoucher = duLieuVoucher.map(x => x.TenMaGG.length > 20 ? x.TenMaGG.substring(0, 20) + '...' : x.TenMaGG);
        var dataSoLanSuDung = duLieuVoucher.map(x => x.SoLanSuDung);
        var dataTongTienGiam = duLieuVoucher.map(x => x.TongTienGiam);

        new Chart(document.getElementById("soSanhChart"), {
            type: "bar",
            data: {
                labels: labelsVoucher,
                datasets: [
                    {
                        label: "Số lần sử dụng",
                        data: dataSoLanSuDung,
                        backgroundColor: "rgba(59, 130, 246, 0.6)",
                        borderColor: "#3b82f6",
                        borderWidth: 1
                    },
                    {
                        label: "Tổng tiền giảm (VND)",
                        data: dataTongTienGiam,
                        backgroundColor: "rgba(239, 68, 68, 0.6)",
                        borderColor: "#ef4444",
                        borderWidth: 1,
                        yAxisID: 'y1'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    }
                },
                scales: {
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        title: {
                            display: true,
                            text: 'Số lần sử dụng'
                        },
                        beginAtZero: true
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        title: {
                            display: true,
                            text: 'Tiền giảm (VND)'
                        },
                        grid: {
                            drawOnChartArea: false
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    } else {
        document.getElementById("soSanhChart").parentElement.innerHTML = '<div class="text-center py-12 text-gray-500 dark:text-gray-400"><p>Chưa có dữ liệu</p></div>';
    }
</script>

