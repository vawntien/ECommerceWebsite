@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
    @model ECommerceWebsiteMVC_Admin.Models.NhanVien

    var TongSoNguoiBan = Convert.ToInt32(ViewBag.TongSoNguoiBan);
    var TongSoNguoiMua = Convert.ToInt32(ViewBag.TongSoNguoiMua);
    var SoCuaHangBiKhoa = Convert.ToInt32(ViewBag.SoCuaHangBiKhoa);
    var TongSoNhanVien = Convert.ToInt32(ViewBag.TongSoNhanVien);

    var buyer = TongSoNguoiMua;
    var seller = TongSoNguoiBan;
    var total = buyer + seller;

    // Tính %
    var buyerPercent = total > 0 ? Math.Round((double)buyer / total * 100, 2) : 0;
    var sellerPercent = 100 - buyerPercent;
}

<!-- PageHeading -->
<div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-col gap-1">
        <h1 class="text-[#181210] dark:text-white text-3xl font-bold leading-tight tracking-tight">Tổng quan</h1>
        <p class="text-gray-500 dark:text-gray-400 text-base font-normal leading-normal">Chào mừng quay trở lại, @Model.HoVaTen!</p>
    </div>
    @*<button class="flex max-w-[480px] cursor-pointer items-center justify-center gap-2 overflow-hidden rounded-lg h-10 min-w-0 px-4 text-sm font-semibold leading-normal bg-primary text-white">
        <span class="material-symbols-outlined text-base">add_circle</span>
        <span>Tạo mới</span>
    </button>*@
</div>

<!-- Stats -->
<div class="grid grid-cols-1 gap-6 pt-6 sm:grid-cols-2 lg:grid-cols-4">

    <div class="flex flex-col gap-2 rounded-lg p-6 bg-white dark:bg-background-dark dark:border dark:border-white/10 shadow-sm">
        <div class="flex items-center justify-between">
            <p class="text-gray-600 dark:text-gray-300 text-base font-medium leading-normal">Tổng số người bán</p>
            <span class="material-symbols-outlined text-primary">storefront</span>
        </div>
        <p class="text-[#181210] dark:text-white tracking-tight text-3xl font-bold leading-tight">@TongSoNguoiBan</p>
    </div>

    <div class="flex flex-col gap-2 rounded-lg p-6 bg-white dark:bg-background-dark dark:border dark:border-white/10 shadow-sm">
        <div class="flex items-center justify-between">
            <p class="text-gray-600 dark:text-gray-300 text-base font-medium leading-normal">Tổng số người mua</p>
            <span class="material-symbols-outlined text-primary">groups</span>
        </div>
        <p class="text-[#181210] dark:text-white tracking-tight text-3xl font-bold leading-tight">@TongSoNguoiMua</p>
    </div>

    <div class="flex flex-col gap-2 rounded-lg p-6 bg-white dark:bg-background-dark dark:border dark:border-white/10 shadow-sm">
        <div class="flex items-center justify-between">
            <p class="text-gray-600 dark:text-gray-300 text-base font-medium leading-normal">Cửa hàng bị khóa</p>
            <span class="material-symbols-outlined text-primary">lock</span>
        </div>
        <p class="text-[#181210] dark:text-white tracking-tight text-3xl font-bold leading-tight">@SoCuaHangBiKhoa</p>
    </div>

    <div class="flex flex-col gap-2 rounded-lg p-6 bg-white dark:bg-background-dark dark:border dark:border-white/10 shadow-sm">
        <div class="flex items-center justify-between">
            <p class="text-gray-600 dark:text-gray-300 text-base font-medium leading-normal">Tổng số nhân viên</p>
            <span class="material-symbols-outlined text-primary">person</span>
        </div>
        <p class="text-[#181210] dark:text-white tracking-tight text-3xl font-bold leading-tight">@TongSoNhanVien</p>
    </div>

</div>

<!-- Charts -->
<div class="grid grid-cols-1 gap-6 pt-6 lg:grid-cols-3">

    <!-- Donut Chart Card -->
    <div class="lg:col-span-2 flex flex-col gap-4 rounded-lg bg-white dark:bg-background-dark dark:border dark:border-white/10 p-6 shadow-sm">

        <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-gray-800 dark:text-white">Phân loại người dùng</h3>
            @*<a class="text-sm font-medium text-primary hover:underline" href="#">Xem chi tiết</a>*@
        </div>

        <div class="flex flex-col items-center justify-center gap-6 sm:flex-row">

            <!-- DONUT -->
            <div class="relative flex h-48 w-48 items-center justify-center">
                <svg class="h-full w-full -rotate-90 transform" viewBox="0 0 36 36">

                    <!-- Nền -->
                    <circle class="text-gray-200 dark:text-gray-700"
                            cx="18" cy="18" r="16"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="4"></circle>

                    <!-- Vùng buyer -->
                    <circle class="text-primary"
                            cx="18" cy="18" r="16"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="4"
                            stroke-linecap="round"
                            stroke-dasharray="@buyerPercent, 100">
                    </circle>

                </svg>

                <!-- TOTAL -->
                <div class="absolute flex flex-col items-center">
                    <span class="text-2xl font-bold text-gray-800 dark:text-white">@total</span>
                    <span class="text-sm text-gray-500 dark:text-gray-400">Tổng số</span>
                </div>
            </div>

            <!-- Legend -->
            <div class="flex flex-col gap-4">

                <div class="flex items-center gap-3">
                    <div class="h-3 w-3 rounded-full bg-primary"></div>
                    <div>
                        <p class="font-semibold text-gray-700 dark:text-gray-200">Người mua</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            @buyer (@buyerPercent%)
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <div class="h-3 w-3 rounded-full bg-gray-200 dark:bg-gray-700"></div>
                    <div>
                        <p class="font-semibold text-gray-700 dark:text-gray-200">Người bán</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            @seller (@sellerPercent%)
                        </p>
                    </div>
                </div>

            </div>

        </div>

    </div>
    <!-- System Notifications Card -->
