@using ECommerceWebsiteMVC_Admin.Models
@model CampaignInfo
@{
    ViewBag.Title = "Thêm Campaign";
    Layout = "~/Views/Shared/_QuanLyNguoiDungHeThongLayout.cshtml";
    var danhMucs = ViewBag.DanhMucs as List<DanhMuc> ?? new List<DanhMuc>();
    var sanPhams = ViewBag.SanPhams as List<SanPham> ?? new List<SanPham>();
}

<!-- PageHeading -->
<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex flex-col gap-1">
        <h1 class="text-[#181210] dark:text-white text-3xl font-bold leading-tight tracking-tight">Thêm Campaign</h1>
        <p class="text-gray-500 dark:text-gray-400 text-base font-normal leading-normal">Tạo chương trình khuyến mãi chủ động mới</p>
    </div>
</div>

<div class="bg-white dark:bg-[#2c1d17] rounded-lg shadow-sm p-6 max-w-5xl">

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 p-4 bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-300 rounded-lg">
            @ViewBag.Error
        </div>
    }

    <form method="post" class="space-y-6">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Tên Campaign -->
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Tên Campaign <span class="text-red-500">*</span>
                </label>
                <input name="TenCampaign" 
                       value="@(Model != null ? Model.TenCampaign : "")"
                       required
                       placeholder="VD: Flash Sale Black Friday"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Mô tả -->
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Mô tả
                </label>
                <textarea name="MoTa" 
                          rows="3"
                          placeholder="Mô tả về chương trình khuyến mãi..."
                          class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                                 focus:ring-primary focus:border-primary text-sm">@(Model != null ? Model.MoTa : "")</textarea>
            </div>

            <!-- Loại giảm giá -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Loại giảm giá <span class="text-red-500">*</span>
                </label>
                <select name="LoaiGiamGia" 
                        required
                        class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                               focus:ring-primary focus:border-primary text-sm">
                    <option value="PhanTram" @(Model != null && Model.LoaiGiamGia == "PhanTram" ? "selected" : "")>Phần trăm (%)</option>
                    <option value="SoTien" @(Model != null && Model.LoaiGiamGia == "SoTien" ? "selected" : "")>Số tiền cố định (đ)</option>
                </select>
            </div>

            <!-- Giá trị giảm -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Giá trị giảm <span class="text-red-500">*</span>
                </label>
                <input type="number" 
                       name="GiaTriGiam" 
                       value="@(Model != null ? Model.GiaTriGiam.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")"
                       min="0"
                       step="0.01"
                       required
                       placeholder="VD: 20 (nếu phần trăm) hoặc 50000 (nếu số tiền)"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    Nếu chọn phần trăm: nhập số từ 0-100 (VD: 20 = 20%)<br />
                    Nếu chọn số tiền: nhập số tiền giảm (VD: 50000 = 50,000đ)
                </p>
            </div>

            <!-- Ngày bắt đầu -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Ngày bắt đầu
                </label>
                <input type="datetime-local" 
                       name="NgayBD" 
                       value="@(Model != null && Model.NgayBD.HasValue ? Model.NgayBD.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

            <!-- Ngày kết thúc -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Ngày kết thúc
                </label>
                <input type="datetime-local" 
                       name="NgayKT" 
                       value="@(Model != null && Model.NgayKT.HasValue ? Model.NgayKT.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                       class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-transparent
                              focus:ring-primary focus:border-primary text-sm" />
            </div>

        </div>

        <!-- Chọn sản phẩm và danh mục -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 pt-6 border-t dark:border-gray-700">
            
            <!-- Chọn sản phẩm -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Chọn sản phẩm
                </label>
                <div class="border border-gray-300 dark:border-gray-600 rounded-md p-4 max-h-64 overflow-y-auto">
                    @if (sanPhams.Any())
                    {
                        foreach (var sp in sanPhams)
                        {
                            <label class="flex items-center gap-2 mb-2 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800 p-2 rounded">
                                <input type="checkbox" 
                                       name="selectedSanPhams" 
                                       value="@sp.MaSanPham"
                                       class="rounded border-gray-300 dark:border-gray-600" />
                                <span class="text-sm">@sp.TenSanPham</span>
                            </label>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-gray-500 dark:text-gray-400">Chưa có sản phẩm nào</p>
                    }
                </div>
            </div>

            <!-- Chọn danh mục -->
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                    Chọn danh mục
                </label>
                <div class="border border-gray-300 dark:border-gray-600 rounded-md p-4 max-h-64 overflow-y-auto">
                    @if (danhMucs.Any())
                    {
                        foreach (var dm in danhMucs)
                        {
                            <label class="flex items-center gap-2 mb-2 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800 p-2 rounded">
                                <input type="checkbox" 
                                       name="selectedDanhMucs" 
                                       value="@dm.MaDanhMuc"
                                       class="rounded border-gray-300 dark:border-gray-600" />
                                <span class="text-sm">@dm.TenDanhMuc</span>
                            </label>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-gray-500 dark:text-gray-400">Chưa có danh mục nào</p>
                    }
                </div>
            </div>

        </div>

        <div class="text-sm text-red-500 mt-2">
            <strong>Lưu ý:</strong> Bạn phải chọn ít nhất một sản phẩm hoặc một danh mục để campaign có hiệu lực.
        </div>

        <!-- Buttons -->
        <div class="flex justify-end gap-3 pt-4 border-t dark:border-gray-700">
            <a href="@Url.Action("QuanLyCampaign", "QuanLyNguoiDungHeThong")" 
               class="px-6 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-200 dark:bg-gray-700 rounded-md hover:bg-gray-300 dark:hover:bg-gray-600">
                Hủy
            </a>
            <button type="submit" 
                    class="px-6 py-2 text-sm font-medium text-white bg-primary rounded-md hover:bg-orange-600">
                Lưu
            </button>
        </div>

    </form>

</div>

